@model IEnumerable<PECCI_HRIS.ViewModels.PayslipViewModel>
@{
    ViewData["Title"] = "My Payslips";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int month = ViewBag.Month;
    int year  = ViewBag.Year;
}

<div class="page-header no-print">
    <div>
        <h1><i class="fas fa-file-invoice-dollar me-2"></i>My Payslips</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">My Payslips</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Month/Year filter -->
<div class="card mb-3 no-print">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small mb-1">Month</label>
                <select name="month" class="form-select form-select-sm">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == month)">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                        </option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small mb-1">Year</label>
                <input type="number" name="year" class="form-control form-control-sm"
                       value="@year" min="2020" max="2099" style="width:90px;" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-pecci-primary">
                    <i class="fas fa-search me-1"></i> View
                </button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fas fa-file-invoice-dollar fa-3x mb-3 d-block opacity-25"></i>
            No payslips found for @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month) @year.
            <div class="small mt-1">Payslips are available once HR finalizes payroll for the period.</div>
        </div>
    </div>
}

@foreach (var slip in Model)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>@slip.CompanyName</strong>
                <div class="text-muted small">@slip.CompanyAddress</div>
            </div>
            <div class="d-flex gap-2 no-print">
                <a asp-action="DownloadPdf" asp-route-id="@slip.PayrollID"
                   class="btn btn-sm btn-success">
                    <i class="fas fa-file-pdf me-1"></i> Download PDF
                </a>
                <button onclick="window.print()" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-print me-1"></i> Print
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="text-muted small">Employee</div>
                    <div class="fw-bold fs-6">@slip.EmployeeName</div>
                    <div class="text-muted small">@slip.EmployeeNo — @slip.Department</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Pay Period</div>
                    <div class="fw-semibold">@slip.PayPeriod</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Days Worked</div>
                    <div class="fw-semibold">@slip.DaysWorked / @(slip.DaysWorked + slip.DaysAbsent)</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="fw-bold mb-2" style="color:var(--pecci-green);border-bottom:2px solid var(--pecci-green);padding-bottom:4px;">
                        <i class="fas fa-plus-circle me-1"></i> Earnings
                    </div>
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr><td>Basic Salary</td><td class="text-end">₱@slip.BasicSalary.ToString("N2")</td></tr>
                            @if (slip.OvertimePay > 0) { <tr><td>Overtime Pay</td><td class="text-end">₱@slip.OvertimePay.ToString("N2")</td></tr> }
                            @if (slip.HolidayPay > 0) { <tr><td>Holiday Pay</td><td class="text-end">₱@slip.HolidayPay.ToString("N2")</td></tr> }
                            @if (slip.NightDifferential > 0) { <tr><td>Night Differential</td><td class="text-end">₱@slip.NightDifferential.ToString("N2")</td></tr> }
                            @if (slip.Allowances > 0) { <tr><td>Allowances</td><td class="text-end">₱@slip.Allowances.ToString("N2")</td></tr> }
                            <tr style="border-top:2px solid var(--pecci-border);font-weight:700;">
                                <td>Gross Pay</td>
                                <td class="text-end" style="color:var(--pecci-green);">₱@slip.GrossPay.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="col-md-6">
                    <div class="fw-bold mb-2" style="color:var(--pecci-orange);border-bottom:2px solid var(--pecci-orange);padding-bottom:4px;">
                        <i class="fas fa-minus-circle me-1"></i> Deductions
                    </div>
                    <table class="table table-sm mb-0">
                        <tbody>
                            @if (slip.SSSContribution > 0) { <tr><td>SSS</td><td class="text-end">₱@slip.SSSContribution.ToString("N2")</td></tr> }
                            @if (slip.PhilHealthContribution > 0) { <tr><td>PhilHealth</td><td class="text-end">₱@slip.PhilHealthContribution.ToString("N2")</td></tr> }
                            @if (slip.PagIbigContribution > 0) { <tr><td>Pag-IBIG</td><td class="text-end">₱@slip.PagIbigContribution.ToString("N2")</td></tr> }
                            @if (slip.WithholdingTax > 0) { <tr><td>Withholding Tax</td><td class="text-end">₱@slip.WithholdingTax.ToString("N2")</td></tr> }
                            @if (slip.LateDeductions > 0) { <tr><td>Late Deductions</td><td class="text-end">₱@slip.LateDeductions.ToString("N2")</td></tr> }
                            @if (slip.UndertimeDeductions > 0) { <tr><td>Undertime</td><td class="text-end">₱@slip.UndertimeDeductions.ToString("N2")</td></tr> }
                            @if (slip.OtherDeductions > 0) { <tr><td>Other Deductions</td><td class="text-end">₱@slip.OtherDeductions.ToString("N2")</td></tr> }
                            <tr style="border-top:2px solid var(--pecci-border);font-weight:700;">
                                <td>Total Deductions</td>
                                <td class="text-end text-danger">₱@slip.TotalDeductions.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-3 p-3 rounded text-center" style="background:var(--pecci-green);color:white;">
                <div class="small mb-1">NET PAY</div>
                <div style="font-size:1.8rem;font-weight:800;">₱@slip.NetPay.ToString("N2")</div>
            </div>

            <div class="text-muted text-end mt-2" style="font-size:0.7rem;">
                Generated: @slip.GeneratedAt.ToString("MMMM dd, yyyy hh:mm tt")
            </div>
        </div>
    </div>
}

<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
