@model PECCI_HRIS.ViewModels.PayrollComputeViewModel
@{
    ViewData["Title"] = "Compute Payroll";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-calculator me-2"></i>Compute Payroll</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active">Compute</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <!-- Info Box -->
        <div class="alert mb-4" style="background:var(--pecci-green-pale);border:1px solid var(--pecci-green);color:var(--pecci-green-dark);">
            <h6 class="fw-bold mb-2"><i class="fas fa-info-circle me-1"></i> What will be computed?</h6>
            <ul class="mb-0 small">
                <li>Basic salary based on days worked and cutoff period</li>
                <li>Overtime pay from attendance records (OT hours × hourly rate × 1.25)</li>
                <li>Late and undertime deductions from attendance logs</li>
                <li>Government contributions: SSS, PhilHealth, Pag-IBIG</li>
                <li>Withholding tax based on BIR tax brackets</li>
                <li>Holiday pay and night differential if applicable</li>
            </ul>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="fas fa-cog me-1"></i> Payroll Parameters
            </div>
            <div class="card-body">
                <form asp-action="Compute" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Cutoff Period <span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input asp-for="CutoffPeriod" class="form-check-input" type="radio" value="1-15" id="cutoff1" />
                                <label class="form-check-label" for="cutoff1">
                                    <strong>1st – 15th</strong>
                                    <div class="text-muted small">First half of the month</div>
                                </label>
                            </div>
                            <div class="form-check">
                                <input asp-for="CutoffPeriod" class="form-check-input" type="radio" value="16-30" id="cutoff2" />
                                <label class="form-check-label" for="cutoff2">
                                    <strong>16th – 30th/31st</strong>
                                    <div class="text-muted small">Second half of the month</div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="CutoffPeriod" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Month" class="form-label fw-semibold">
                                Month <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Month" class="form-select">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                                }
                            </select>
                            <span asp-validation-for="Month" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Year" class="form-label fw-semibold">
                                Year <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Year" class="form-control" type="number" min="2020" max="2099" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="EmployeeID" class="form-label fw-semibold">
                            Employee <span class="text-muted small">(optional — leave blank to compute all)</span>
                        </label>
                        <select asp-for="EmployeeID" asp-items="Model.Employees" class="form-select">
                            <option value="">All Active Employees</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-pecci-primary">
                            <i class="fas fa-play me-1"></i> Run Computation
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
