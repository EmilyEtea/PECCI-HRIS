@model IEnumerable<PECCI_HRIS.ViewModels.PayslipViewModel>
@{
    ViewData["Title"] = "Payslips";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header no-print">
    <div>
        <h1><i class="fas fa-file-invoice-dollar me-2"></i>Payslips</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active">Payslips</li>
            </ol>
        </nav>
    </div>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print">
        <i class="fas fa-print me-1"></i> Print All
    </button>
    <a asp-action="DownloadAllPdf"
       asp-route-month="@ViewBag.Month"
       asp-route-year="@ViewBag.Year"
       asp-route-employeeId="@ViewBag.EmployeeId"
       class="btn btn-pecci-primary no-print">
        <i class="fas fa-file-pdf me-1"></i> Download All PDF
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fas fa-file-invoice-dollar fa-3x mb-3 d-block opacity-25"></i>
            No payslips found. Please compute payroll first.
        </div>
    </div>
}

@foreach (var slip in Model)
{
    <div class="card mb-4 payslip-card">
        <!-- Payslip Header -->
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>@slip.CompanyName</strong>
                <div class="text-muted small">@slip.CompanyAddress</div>
            </div>
            <button onclick="printSlip('@slip.PayrollID')" class="btn btn-sm btn-outline-secondary no-print">
                <i class="fas fa-print me-1"></i> Print
            </button>
            <a asp-action="DownloadPdf" asp-route-id="@slip.PayrollID"
               class="btn btn-sm btn-pecci-primary no-print">
                <i class="fas fa-file-pdf me-1"></i> PDF
            </a>
        </div>
        <div class="card-body" id="slip-@slip.PayrollID">
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="text-muted small">Employee</div>
                    <div class="fw-bold fs-6">@slip.EmployeeName</div>
                    <div class="text-muted small">@slip.EmployeeNo — @slip.Department</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Pay Period</div>
                    <div class="fw-semibold">@slip.PayPeriod</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Days Worked</div>
                    <div class="fw-semibold">@slip.DaysWorked / @(slip.DaysWorked + slip.DaysAbsent)</div>
                </div>
            </div>

            <div class="row">
                <!-- Earnings -->
                <div class="col-md-6">
                    <div class="fw-bold mb-2" style="color:var(--pecci-green);border-bottom:2px solid var(--pecci-green);padding-bottom:4px;">
                        <i class="fas fa-plus-circle me-1"></i> Earnings
                    </div>
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <td>Basic Salary</td>
                                <td class="text-end">₱@slip.BasicSalary.ToString("N2")</td>
                            </tr>
                            @if (slip.OvertimePay > 0)
                            {
                                <tr>
                                    <td>Overtime Pay</td>
                                    <td class="text-end">₱@slip.OvertimePay.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.HolidayPay > 0)
                            {
                                <tr>
                                    <td>Holiday Pay</td>
                                    <td class="text-end">₱@slip.HolidayPay.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.NightDifferential > 0)
                            {
                                <tr>
                                    <td>Night Differential</td>
                                    <td class="text-end">₱@slip.NightDifferential.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.Allowances > 0)
                            {
                                <tr>
                                    <td>Allowances</td>
                                    <td class="text-end">₱@slip.Allowances.ToString("N2")</td>
                                </tr>
                            }
                            <tr style="border-top:2px solid var(--pecci-border);font-weight:700;">
                                <td>Gross Pay</td>
                                <td class="text-end" style="color:var(--pecci-green);">₱@slip.GrossPay.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Deductions -->
                <div class="col-md-6">
                    <div class="fw-bold mb-2" style="color:var(--pecci-orange);border-bottom:2px solid var(--pecci-orange);padding-bottom:4px;">
                        <i class="fas fa-minus-circle me-1"></i> Deductions
                    </div>
                    <table class="table table-sm mb-0">
                        <tbody>
                            @if (slip.SSSContribution > 0)
                            {
                                <tr>
                                    <td>SSS</td>
                                    <td class="text-end">₱@slip.SSSContribution.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.PhilHealthContribution > 0)
                            {
                                <tr>
                                    <td>PhilHealth</td>
                                    <td class="text-end">₱@slip.PhilHealthContribution.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.PagIbigContribution > 0)
                            {
                                <tr>
                                    <td>Pag-IBIG</td>
                                    <td class="text-end">₱@slip.PagIbigContribution.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.WithholdingTax > 0)
                            {
                                <tr>
                                    <td>
                                        Withholding Tax
                                        @if (!string.IsNullOrEmpty(slip.TaxBracket))
                                        {
                                            <span class="badge bg-secondary ms-1" style="font-size:0.65rem;">@slip.TaxBracket</span>
                                        }
                                    </td>
                                    <td class="text-end">₱@slip.WithholdingTax.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.LateDeductions > 0)
                            {
                                <tr>
                                    <td>Late Deductions</td>
                                    <td class="text-end">₱@slip.LateDeductions.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.UndertimeDeductions > 0)
                            {
                                <tr>
                                    <td>Undertime</td>
                                    <td class="text-end">₱@slip.UndertimeDeductions.ToString("N2")</td>
                                </tr>
                            }
                            @if (slip.OtherDeductions > 0)
                            {
                                <tr>
                                    <td>Other Deductions</td>
                                    <td class="text-end">₱@slip.OtherDeductions.ToString("N2")</td>
                                </tr>
                            }
                            <tr style="border-top:2px solid var(--pecci-border);font-weight:700;">
                                <td>Total Deductions</td>
                                <td class="text-end text-danger">₱@slip.TotalDeductions.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Net Pay -->
            <div class="mt-3 p-3 rounded text-center" style="background:var(--pecci-green);color:white;">
                <div class="small mb-1">NET PAY</div>
                <div style="font-size:1.8rem;font-weight:800;">₱@slip.NetPay.ToString("N2")</div>
            </div>

            <div class="text-muted text-end mt-2" style="font-size:0.7rem;">
                Generated: @slip.GeneratedAt.ToString("MMMM dd, yyyy hh:mm tt")
            </div>
        </div>
    </div>
}

<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
<script>
    function printSlip(id) {
        const content = document.getElementById('slip-' + id).innerHTML;
        const win = window.open('', '_blank', 'width=800,height=600');
        win.document.write(`
            <html><head><title>Payslip</title>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
            <style>body{padding:20px;font-family:Arial,sans-serif;}</style>
            </head><body>${content}</body></html>`);
        win.document.close();
        win.print();
    }
</script>
}
