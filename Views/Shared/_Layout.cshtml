@using System.Security.Claims
@{
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
    var role     = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var initials = string.Concat(fullName.Split(' ').Take(2).Select(w => w.FirstOrDefault()));
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction     = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavClass(string ctrl, string? action = null) =>
        currentController.Equals(ctrl, StringComparison.OrdinalIgnoreCase) &&
        (action == null || currentAction.Equals(action, StringComparison.OrdinalIgnoreCase))
            ? "nav-link active" : "nav-link";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – PECCI HRIS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/pecci-theme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ── Sidebar ──────────────────────────────────────────────────────────────── -->
<nav class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div style="width:42px;height:42px;background:white;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:900;color:var(--pecci-blue);font-size:1rem;flex-shrink:0;">P</div>
        <div class="sidebar-brand-text">
            <div class="brand-title">PECCI HRIS</div>
            <div class="brand-sub">HR Information System</div>
        </div>
    </div>

    <div class="sidebar-nav">
        <!-- Dashboard -->
        <a asp-controller="Dashboard" asp-action="Index" class="@NavClass("Dashboard")">
            <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>

        <!-- Employee Management -->
        <div class="nav-section-label">Employee</div>
        <a asp-controller="Employee" asp-action="Index" class="@NavClass("Employee")">
            <i class="fas fa-users"></i> Employees
        </a>
        <a asp-controller="Department" asp-action="Index" class="@NavClass("Department")">
            <i class="fas fa-building"></i> Departments
        </a>
        <a asp-controller="Position" asp-action="Index" class="@NavClass("Position")">
            <i class="fas fa-briefcase"></i> Positions
        </a>

        <!-- Attendance -->
        <div class="nav-section-label">Timekeeping</div>
        <a asp-controller="Attendance" asp-action="Index" class="@NavClass("Attendance","Index")">
            <i class="fas fa-clock"></i> Attendance
        </a>
        <a asp-controller="Attendance" asp-action="Summary" class="@NavClass("Attendance","Summary")">
            <i class="fas fa-calendar-check"></i> Attendance Summary
        </a>

        <!-- Leave -->
        <div class="nav-section-label">Leave</div>
        <a asp-controller="Leave" asp-action="Index" class="@NavClass("Leave","Index")">
            <i class="fas fa-calendar-minus"></i> Leave Applications
        </a>
        <a asp-controller="Leave" asp-action="Credits" class="@NavClass("Leave","Credits")">
            <i class="fas fa-coins"></i> Leave Credits
        </a>
        @if (role == "HR Admin" || role == "HR Staff")
        {
            <a asp-controller="Leave" asp-action="Types" class="@NavClass("Leave","Types")">
                <i class="fas fa-tags"></i> Leave Types
            </a>
        }

        <!-- Payroll -->
        @if (role == "HR Admin" || role == "HR Staff")
        {
            <div class="nav-section-label">Payroll</div>
            <a asp-controller="Payroll" asp-action="Index" class="@NavClass("Payroll","Index")">
                <i class="fas fa-money-bill-wave"></i> Payroll
            </a>
            <a asp-controller="Payroll" asp-action="Compute" class="@NavClass("Payroll","Compute")">
                <i class="fas fa-calculator"></i> Compute Payroll
            </a>
            <a asp-controller="Payroll" asp-action="Payslips" class="@NavClass("Payroll","Payslips")">
                <i class="fas fa-file-invoice-dollar"></i> Payslips
            </a>
        }

        <!-- Reports -->
        @if (role == "HR Admin" || role == "HR Staff" || role == "Manager")
        {
            <div class="nav-section-label">Reports</div>
            <a asp-controller="Reports" asp-action="Index" class="@NavClass("Reports")">
                <i class="fas fa-chart-bar"></i> Reports
            </a>
        }

        <!-- Admin -->
        @if (role == "HR Admin")
        {
            <div class="nav-section-label">Administration</div>
            <a asp-controller="Users" asp-action="Index" class="@NavClass("Users")">
                <i class="fas fa-user-shield"></i> User Management
            </a>
            <a asp-controller="Settings" asp-action="Index" class="@NavClass("Settings")">
                <i class="fas fa-sliders-h"></i> System Settings
            </a>
            <a asp-controller="AuditLog" asp-action="Index" class="@NavClass("AuditLog")">
                <i class="fas fa-history"></i> Audit Trail
            </a>
        }
    </div>

    <div class="sidebar-footer">
        <div>UST Interns</div>
        <div>Aguilar · De Guzman · Soriano · Etea</div>
        <div style="margin-top:0.25rem;opacity:0.6;">v1.0.0 &copy; 2026 PECCI</div>
    </div>
</nav>

<!-- ── Top Bar ───────────────────────────────────────────────────────────────── -->
<header class="topbar">
    <div class="topbar-left">
        <button class="btn btn-sm btn-outline-secondary d-md-none" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>
        <span class="topbar-title">@ViewData["Title"]</span>
    </div>
    <div class="topbar-right">
        <!-- Notifications -->
        <div class="dropdown">
            <button class="btn btn-sm btn-light position-relative" data-bs-toggle="dropdown">
                <i class="fas fa-bell"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;">
                    @ViewBag.PendingLeaveCount
                </span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="min-width:280px;">
                <li><h6 class="dropdown-header">Notifications</h6></li>
                <li><a class="dropdown-item small" asp-controller="Leave" asp-action="Index">
                    <i class="fas fa-calendar-minus text-warning me-2"></i>
                    Pending leave applications
                </a></li>
            </ul>
        </div>

        <!-- User Menu -->
        <div class="dropdown">
            <div class="topbar-user" data-bs-toggle="dropdown">
                <div class="avatar">@initials.ToUpper()</div>
                <div class="user-info d-none d-md-block">
                    <div class="user-name">@fullName</div>
                    <div class="user-role">@role</div>
                </div>
                <i class="fas fa-chevron-down ms-1 text-muted" style="font-size:0.7rem;"></i>
            </div>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><h6 class="dropdown-header">@fullName</h6></li>
                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                    <i class="fas fa-user me-2"></i> My Profile
                </a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="fas fa-sign-out-alt me-2"></i> Logout
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</header>

<!-- ── Main Content ──────────────────────────────────────────────────────────── -->
<main class="main-content">
    <!-- Toast Notifications -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible alert-pecci fade show mb-3" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible alert-pecci fade show mb-3" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible alert-pecci fade show mb-3" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Sidebar toggle for mobile
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        document.getElementById('sidebar').classList.toggle('show');
    });

    // Auto-dismiss alerts after 5 seconds
    setTimeout(() => {
        document.querySelectorAll('.alert.fade.show').forEach(el => {
            new bootstrap.Alert(el).close();
        });
    }, 5000);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
