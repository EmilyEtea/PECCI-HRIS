@model PECCI_HRIS.Models.User
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-user-circle me-2"></i>My Profile</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Profile</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <!-- Account Info -->
    <div class="col-md-5 col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-id-card me-1"></i> Account Information
            </div>
            <div class="card-body text-center">
                <!-- Avatar -->
                <div class="mx-auto mb-3" style="width:80px;height:80px;border-radius:50%;background:var(--pecci-green);color:white;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;">
                    @Model.Username.FirstOrDefault().ToString().ToUpper()
                </div>
                <h5 class="fw-bold mb-1">@Model.Username</h5>
                <div class="mb-2">
                    <span class="badge" style="background:var(--pecci-green-pale);color:var(--pecci-green);font-size:0.85rem;">
                        @Model.Role?.RoleName
                    </span>
                </div>
                <div class="text-muted small mb-3">@Model.Email</div>
                <div class="d-flex justify-content-center gap-2">
                    <span class="status-badge @(Model.IsActive ? "badge-active" : "badge-inactive")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>
            <div class="card-body border-top pt-3">
                <div class="row g-2 text-center">
                    <div class="col-6">
                        <div class="text-muted small">Member Since</div>
                        <div class="fw-semibold small">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Last Login</div>
                        <div class="fw-semibold small">
                            @(Model.LastLogin.HasValue ? Model.LastLogin.Value.ToString("MMM dd, yyyy") : "—")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Employee Details -->
    <div class="col-md-7 col-lg-8">
        @if (Model.Employee != null)
        {
            var emp = Model.Employee;
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-user-tie me-1"></i> Employee Details
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Full Name</div>
                            <div class="fw-semibold">@emp.FullName</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Employee No.</div>
                            <div class="fw-semibold" style="color:var(--pecci-green);">@emp.EmployeeNo</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Department</div>
                            <div class="fw-semibold">@emp.Department?.DepartmentName</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Position</div>
                            <div class="fw-semibold">@emp.Position?.PositionTitle</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Date Hired</div>
                            <div>@emp.DateHired.ToString("MMMM dd, yyyy")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Employment Status</div>
                            <div>@emp.EmploymentStatus</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Contact Number</div>
                            <div>@(emp.ContactNumber ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Company Email</div>
                            <div>@(emp.CompanyEmail ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Gender</div>
                            <div>@emp.Gender</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Civil Status</div>
                            <div>@(emp.CivilStatus ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Government IDs -->
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-id-badge me-1"></i> Government IDs
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">SSS Number</div>
                            <div class="fw-semibold">@(emp.SSSNumber ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">PhilHealth Number</div>
                            <div class="fw-semibold">@(emp.PhilHealthNumber ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Pag-IBIG Number</div>
                            <div class="fw-semibold">@(emp.PagIbigNumber ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">TIN Number</div>
                            <div class="fw-semibold">@(emp.TINNumber ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center text-muted py-5">
                    <i class="fas fa-user-slash fa-3x mb-3 d-block opacity-25"></i>
                    <p>This account is not linked to an employee record.</p>
                    <p class="small">Contact HR Admin to link your account to an employee profile.</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
