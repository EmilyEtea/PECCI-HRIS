@model PECCI_HRIS.ViewModels.OvertimeRequestViewModel
@{
    ViewData["Title"] = "File Overtime Request";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-business-time me-2"></i>File Overtime Request</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Overtime Requests</a></li>
                <li class="breadcrumb-item active">File Request</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-file-alt me-1"></i> Overtime Request Form
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="EmployeeID" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="OvertimeDate" class="form-label fw-semibold">
                            Overtime Date <span class="text-danger">*</span>
                        </label>
                        <input asp-for="OvertimeDate" type="date" class="form-control"
                               value="@Model.OvertimeDate.ToString("yyyy-MM-dd")"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="OvertimeDate" class="text-danger small"></span>
                        <div class="form-text">The date on which the overtime will be worked.</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartTimeString" class="form-label fw-semibold">
                                Start Time <span class="text-danger">*</span>
                            </label>
                            <input asp-for="StartTimeString" type="time" class="form-control"
                                   id="startTime" />
                            <span asp-validation-for="StartTimeString" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTimeString" class="form-label fw-semibold">
                                End Time <span class="text-danger">*</span>
                            </label>
                            <input asp-for="EndTimeString" type="time" class="form-control"
                                   id="endTime" />
                            <span asp-validation-for="EndTimeString" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Live duration display -->
                    <div class="alert alert-info py-2 mb-3" id="durationAlert" style="display:none;">
                        <i class="fas fa-clock me-1"></i>
                        Duration: <strong id="durationDisplay"></strong>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Reason" class="form-label fw-semibold">
                            Reason / Purpose <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Reason" class="form-control" rows="4"
                                  placeholder="Describe the work to be done during overtime..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-pecci-primary">
                            <i class="fas fa-paper-plane me-1"></i> Submit Request
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-3 border-0" style="background:#f8f9fa;">
            <div class="card-body small text-muted">
                <i class="fas fa-info-circle me-1 text-primary"></i>
                <strong>Note:</strong> OT requests must be filed <em>before</em> the overtime is worked.
                Minimum request is 30 minutes. Your request will be reviewed by your Manager and HR.
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function updateDuration() {
            const s = document.getElementById('startTime').value;
            const e = document.getElementById('endTime').value;
            const alert = document.getElementById('durationAlert');
            const disp  = document.getElementById('durationDisplay');
            if (s && e) {
                const [sh, sm] = s.split(':').map(Number);
                const [eh, em] = e.split(':').map(Number);
                const totalMin = (eh * 60 + em) - (sh * 60 + sm);
                if (totalMin > 0) {
                    const h = Math.floor(totalMin / 60);
                    const m = totalMin % 60;
                    disp.textContent = (h > 0 ? h + 'h ' : '') + m + 'min';
                    alert.style.display = 'block';
                } else {
                    alert.style.display = 'none';
                }
            } else {
                alert.style.display = 'none';
            }
        }
        document.getElementById('startTime').addEventListener('change', updateDuration);
        document.getElementById('endTime').addEventListener('change', updateDuration);
        updateDuration();
    </script>
}
