@model PECCI_HRIS.Models.OvertimeRequest
@{
    ViewData["Title"] = "OT Request Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isHR      = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
    bool isManager = User.IsInRole("Manager");
    var badgeClass = Model.Status switch {
        "Approved"    => "badge-approved",
        "Disapproved" => "badge-rejected",
        "Cancelled"   => "badge-inactive",
        _             => "badge-pending"
    };
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-business-time me-2"></i>OT Request Details</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Overtime Requests</a></li>
                <li class="breadcrumb-item active">#@Model.OvertimeRequestID</li>
            </ol>
        </nav>
    </div>
    <span class="status-badge @badgeClass" style="font-size:0.9rem;padding:0.4rem 1rem;">
        @Model.Status
    </span>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header"><i class="fas fa-info-circle me-1"></i> Request Details</div>
            <div class="card-body">
                <div class="row g-3">
                    @if (isHR || isManager)
                    {
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Employee</div>
                            <div class="fw-semibold">@Model.Employee?.FullName</div>
                            <div class="text-muted small">@Model.Employee?.Department?.DepartmentName</div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Overtime Date</div>
                        <div class="fw-semibold">@Model.OvertimeDate.ToString("MMMM dd, yyyy")</div>
                        <div class="text-muted small">@Model.OvertimeDate.ToString("dddd")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small mb-1">Start Time</div>
                        <div class="fw-semibold">@Model.StartTime.ToString(@"hh\:mm tt")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small mb-1">End Time</div>
                        <div class="fw-semibold">@Model.EndTime.ToString(@"hh\:mm tt")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small mb-1">Requested Duration</div>
                        <div class="fw-bold fs-5" style="color:var(--pecci-green);">
                            @Model.RequestedHours.ToString("F2") hrs
                        </div>
                    </div>
                    @if (Model.ApprovedMinutes.HasValue)
                    {
                        <div class="col-md-4">
                            <div class="text-muted small mb-1">Approved Duration</div>
                            <div class="fw-bold fs-5 text-success">
                                @Model.ApprovedHours!.Value.ToString("F2") hrs
                            </div>
                        </div>
                    }
                    <div class="col-12">
                        <div class="text-muted small mb-1">Reason / Purpose</div>
                        <div class="p-3 rounded" style="background:var(--pecci-bg-light);border:1px solid var(--pecci-border);">
                            @(string.IsNullOrEmpty(Model.Reason) ? "No reason provided." : Model.Reason)
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Filed On</div>
                        <div>@Model.AppliedAt.ToString("MMMM dd, yyyy hh:mm tt")</div>
                    </div>
                </div>
            </div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
        @if ((isHR || isManager) && (Model.Status == "Pending" || Model.Status == "Pending HR"))
        {
            <a asp-action="Review" asp-route-id="@Model.OvertimeRequestID"
               class="btn btn-pecci-primary ms-2">
                <i class="fas fa-clipboard-check me-1"></i> Review Request
            </a>
        }
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><i class="fas fa-comments me-1"></i> Approval Remarks</div>
            <div class="card-body">

                @if (Model.ManagerApprovedAt.HasValue)
                {
                    <div class="mb-3 pb-3" style="border-bottom:1px solid var(--pecci-border);">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="fas fa-user-tie text-muted"></i>
                            <span class="fw-semibold small">Manager Review</span>
                            <span class="ms-auto text-muted" style="font-size:0.72rem;">
                                @Model.ManagerApprovedAt.Value.ToString("MM/dd/yyyy hh:mm tt")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ManagerRemarks))
                        {
                            <div class="p-2 rounded" style="background:var(--pecci-bg-light);border:1px solid var(--pecci-border);font-size:0.9rem;">
                                @Model.ManagerRemarks
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small fst-italic">No remarks left by manager.</div>
                        }
                    </div>
                }

                @if (Model.HRApprovedAt.HasValue)
                {
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            @{
                                var hrColor = Model.Status == "Approved" ? "var(--pecci-green)" : "#dc3545";
                                var hrIcon  = Model.Status == "Approved" ? "fa-check-circle" : "fa-times-circle";
                            }
                            <i class="fas @hrIcon" style="color:@hrColor;"></i>
                            <span class="fw-semibold small">HR Decision</span>
                            <span class="status-badge @badgeClass ms-1" style="font-size:0.65rem;padding:0.1rem 0.5rem;">
                                @Model.Status
                            </span>
                            <span class="ms-auto text-muted" style="font-size:0.72rem;">
                                @Model.HRApprovedAt.Value.ToString("MM/dd/yyyy hh:mm tt")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.HRRemarks))
                        {
                            <div class="p-2 rounded" style="background:var(--pecci-bg-light);border:1px solid var(--pecci-border);font-size:0.9rem;">
                                @Model.HRRemarks
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small fst-italic">No remarks left by HR.</div>
                        }
                    </div>
                }

                @if (!Model.ManagerApprovedAt.HasValue && !Model.HRApprovedAt.HasValue)
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-clock fa-2x mb-2 d-block opacity-25"></i>
                        <div class="small">Awaiting review. Remarks will appear here once processed.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
