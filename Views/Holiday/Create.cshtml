@model PECCI_HRIS.ViewModels.HolidayFormViewModel
@{
    ViewData["Title"] = "Add Holiday";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-calendar-plus me-2"></i>Add Holiday</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Holiday Calendar</a></li>
                <li class="breadcrumb-item active">Add Holiday</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-plus me-1"></i> New Holiday Entry
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="HolidayDate" class="form-label fw-semibold">
                            Holiday Date <span class="text-danger">*</span>
                        </label>
                        <input asp-for="HolidayDate" type="date" class="form-control" />
                        <span asp-validation-for="HolidayDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HolidayName" class="form-label fw-semibold">
                            Holiday Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="HolidayName" class="form-control"
                               placeholder="e.g. New Year's Day" maxlength="150" />
                        <span asp-validation-for="HolidayName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HolidayType" class="form-label fw-semibold">
                            Holiday Type <span class="text-danger">*</span>
                        </label>
                        <select asp-for="HolidayType"
                                asp-items="PECCI_HRIS.ViewModels.HolidayFormViewModel.HolidayTypeOptions"
                                class="form-select">
                        </select>
                        <span asp-validation-for="HolidayType" class="text-danger small"></span>
                        <div id="typeHint" class="form-text mt-1"></div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsRecurring" class="form-check-input" type="checkbox" />
                            <label asp-for="IsRecurring" class="form-check-label fw-semibold">
                                Recurring annually
                            </label>
                        </div>
                        <div class="form-text">
                            Check for fixed-date holidays (e.g., Christmas, New Year's Day).
                            Leave unchecked for movable or one-time proclamation dates.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Remarks" class="form-label fw-semibold">Remarks / Notes</label>
                        <textarea asp-for="Remarks" class="form-control" rows="2"
                                  placeholder="e.g., Proclamation No. 727, s. 2025 · In lieu of…"
                                  maxlength="300"></textarea>
                        <span asp-validation-for="Remarks" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-pecci-primary">
                            <i class="fas fa-save me-1"></i> Save Holiday
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Pay rate reference card -->
        <div class="card mt-3">
            <div class="card-header small"><i class="fas fa-info-circle me-1"></i> Pay Rate Reference</div>
            <div class="card-body small">
                <div id="hint-regular" class="d-none">
                    <span class="badge" style="background:#dc3545;">Regular Holiday</span>
                    <ul class="mt-1 mb-0">
                        <li>Did not work → <strong>100%</strong> of daily rate (paid holiday)</li>
                        <li>Worked → <strong>200%</strong> of daily rate</li>
                    </ul>
                </div>
                <div id="hint-special" class="d-none">
                    <span class="badge" style="background:#fd7e14;">Special Non-Working</span>
                    <ul class="mt-1 mb-0">
                        <li>Did not work → <strong>No pay</strong> (no-work, no-pay)</li>
                        <li>Worked → <strong>130%</strong> of daily rate</li>
                    </ul>
                </div>
                <div id="hint-default" class="text-muted">Select a holiday type to see the pay rate.</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const typeSelect = document.getElementById('HolidayType');
        function updateHint() {
            const v = typeSelect.value;
            document.getElementById('hint-regular').classList.toggle('d-none', v !== 'Regular');
            document.getElementById('hint-special').classList.toggle('d-none', v !== 'Special');
            document.getElementById('hint-default').classList.toggle('d-none', v !== '');
        }
        typeSelect.addEventListener('change', updateHint);
        updateHint();
    </script>
}
