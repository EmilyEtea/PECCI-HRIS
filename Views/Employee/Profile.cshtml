@model PECCI_HRIS.Models.Employee
@{
    ViewData["Title"] = $"Profile — {Model.FullName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHR = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
    var leaveCredits = ViewBag.LeaveCredits as List<PECCI_HRIS.Models.LeaveCredit> ?? new();
    var recentAttendance = ViewBag.RecentAttendance as List<PECCI_HRIS.Models.AttendanceRecord> ?? new();
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-user-circle me-2"></i>Employee Profile</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
                <li class="breadcrumb-item active">@Model.FullName</li>
            </ol>
        </nav>
    </div>
    @if (isHR)
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.EmployeeID" class="btn btn-pecci-primary">
                <i class="fas fa-edit me-1"></i> Edit
            </a>
            @if (User.IsInRole("HR Admin") && Model.Status == "Active")
            {
                <button type="button" class="btn btn-outline-danger"
                        data-bs-toggle="modal" data-bs-target="#deactivateModal">
                    <i class="fas fa-user-slash me-1"></i> Deactivate
                </button>
            }
        </div>
    }
</div>

<div class="row g-3">
    <!-- Profile Card -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center py-4">
                <div style="width:80px;height:80px;border-radius:50%;background:var(--pecci-green-pale);color:var(--pecci-green);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;margin:0 auto 1rem;">
                    @(Model.FirstName.FirstOrDefault())@(Model.LastName.FirstOrDefault())
                </div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <div class="text-muted small mb-2">@Model.Position?.PositionTitle</div>
                <span class="status-badge @(Model.Status == "Active" ? "badge-active" : "badge-inactive")">
                    @Model.Status
                </span>
                <hr />
                <div class="text-start" style="font-size:0.82rem;">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Employee No.</span>
                        <strong class="text-success">@Model.EmployeeNo</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Department</span>
                        <strong>@Model.Department?.DepartmentName</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Employment</span>
                        <strong>@Model.EmploymentStatus</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Date Hired</span>
                        <strong>@Model.DateHired.ToString("MM/dd/yyyy")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Age</span>
                        <strong>@Model.Age years old</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leave Credits -->
        <div class="card">
            <div class="card-header"><i class="fas fa-coins me-1"></i> Leave Credits (@DateTime.Today.Year)</div>
            <div class="card-body p-0">
                @if (leaveCredits.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr style="background:var(--pecci-green-pale);">
                                <th class="px-3 py-2 small">Type</th>
                                <th class="px-3 py-2 small text-center">Total</th>
                                <th class="px-3 py-2 small text-center">Used</th>
                                <th class="px-3 py-2 small text-center">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lc in leaveCredits)
                            {
                                <tr>
                                    <td class="px-3 py-2 small">@lc.LeaveType?.LeaveCode</td>
                                    <td class="px-3 py-2 small text-center">@lc.TotalCredits</td>
                                    <td class="px-3 py-2 small text-center">@lc.UsedCredits</td>
                                    <td class="px-3 py-2 small text-center fw-bold @(lc.RemainingCredits <= 0 ? "text-danger" : "text-success")">
                                        @lc.RemainingCredits
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-3 small">No leave credits allocated.</div>
                }
            </div>
        </div>
    </div>

    <!-- Details -->
    <div class="col-md-8">
        <!-- Personal Info -->
        <div class="card mb-3">
            <div class="card-header"><i class="fas fa-address-card me-1"></i> Personal Information</div>
            <div class="card-body">
                <div class="row g-2" style="font-size:0.85rem;">
                    <div class="col-md-4"><span class="text-muted">Gender:</span> <strong>@Model.Gender</strong></div>
                    <div class="col-md-4"><span class="text-muted">Civil Status:</span> <strong>@Model.CivilStatus</strong></div>
                    <div class="col-md-4"><span class="text-muted">Nationality:</span> <strong>@Model.Nationality</strong></div>
                    <div class="col-md-6"><span class="text-muted">Contact:</span> <strong>@Model.ContactNumber</strong></div>
                    <div class="col-md-6"><span class="text-muted">Personal Email:</span> <strong>@Model.PersonalEmail</strong></div>
                    <div class="col-md-12"><span class="text-muted">Address:</span> <strong>@Model.Address</strong></div>
                </div>
                <hr class="my-2" />
                <div class="row g-2" style="font-size:0.85rem;">
                    <div class="col-md-3"><span class="text-muted">SSS:</span> <strong>@(Model.SSSNumber ?? "—")</strong></div>
                    <div class="col-md-3"><span class="text-muted">PhilHealth:</span> <strong>@(Model.PhilHealthNumber ?? "—")</strong></div>
                    <div class="col-md-3"><span class="text-muted">Pag-IBIG:</span> <strong>@(Model.PagIbigNumber ?? "—")</strong></div>
                    <div class="col-md-3"><span class="text-muted">TIN:</span> <strong>@(Model.TINNumber ?? "—")</strong></div>
                </div>
            </div>
        </div>

        <!-- Recent Attendance -->
        <div class="card">
            <div class="card-header">
                <i class="fas fa-clock me-1"></i> Recent Attendance
                <a asp-controller="Attendance" asp-action="Index" asp-route-employeeId="@Model.EmployeeID"
                   class="btn btn-sm btn-outline-success ms-auto" style="font-size:0.75rem;">View All</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-pecci mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time In</th>
                            <th>Time Out</th>
                            <th>Hours</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in recentAttendance)
                        {
                            <tr>
                                <td>@a.AttendanceDate.ToString("MM/dd/yyyy (ddd)")</td>
                                <td class="@(a.IsLate ? "text-danger" : "")">
                                    @(a.TimeIn?.ToString(@"hh\:mm") ?? "—")
                                </td>
                                <td>@(a.TimeOut?.ToString(@"hh\:mm") ?? "—")</td>
                                <td>@(a.TotalHoursWorked?.ToString("F2") ?? "—")</td>
                                <td>
                                    @{
                                        var bc = a.AttendanceStatus switch {
                                            "Present" => "badge-present", "Late" => "badge-late",
                                            "Absent" => "badge-absent", "On Leave" => "badge-on-leave",
                                            _ => "badge-present"
                                        };
                                    }
                                    <span class="status-badge @bc">@a.AttendanceStatus</span>
                                </td>
                            </tr>
                        }
                        @if (!recentAttendance.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">No attendance records.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

<!-- Deactivate Confirmation Modal -->
@if (User.IsInRole("HR Admin") && Model.Status == "Active")
{
    <div class="modal fade" id="deactivateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header border-danger">
                    <h5 class="modal-title text-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>Deactivate Employee
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>You are about to deactivate <strong>@Model.FullName</strong> (@Model.EmployeeNo).</p>
                    <p class="text-muted small mb-3">
                        The employee will be marked as <strong>Inactive</strong> and removed from active payroll,
                        attendance, and leave processing. All historical records are preserved.
                    </p>
                    <form asp-action="Deactivate" asp-route-id="@Model.EmployeeID" method="post" id="deactivateForm">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Reason for Deactivation <span class="text-danger">*</span>
                            </label>
                            <select name="reason" class="form-select" id="deactivateReason" required>
                                <option value="">Select reason...</option>
                                <option value="Resigned">Resigned</option>
                                <option value="Terminated">Terminated</option>
                                <option value="Retired">Retired</option>
                                <option value="End of Contract">End of Contract</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-danger" onclick="submitDeactivate()">
                        <i class="fas fa-user-slash me-1"></i> Confirm Deactivate
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    function submitDeactivate() {
        const reason = document.getElementById('deactivateReason').value;
        if (!reason) {
            alert('Please select a reason for deactivation.');
            return;
        }
        document.getElementById('deactivateForm').submit();
    }
</script>
}
