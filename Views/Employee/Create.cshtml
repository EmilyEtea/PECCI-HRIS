@model PECCI_HRIS.ViewModels.EmployeeViewModel
@{
    ViewData["Title"] = "Add Employee";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool hasErrors = !ViewData.ModelState.IsValid;
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-user-plus me-2"></i>Add New Employee</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
                <li class="breadcrumb-item active">Add Employee</li>
            </ol>
        </nav>
    </div>
</div>

@* ── Validation summary banner — shown only when the form was submitted with errors ── *@
@if (hasErrors)
{
    <div class="alert alert-danger alert-dismissible d-flex gap-3 mb-3" role="alert" id="validationBanner">
        <i class="fas fa-exclamation-circle fa-lg mt-1 flex-shrink-0"></i>
        <div class="flex-grow-1">
            <strong>Please fix the following before saving:</strong>
            <ul class="mb-0 mt-1 ps-3">
                @foreach (var entry in ViewData.ModelState)
                {
                    foreach (var error in entry.Value!.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Create" method="post" id="createEmployeeForm" novalidate>
    @Html.AntiForgeryToken()
    <div class="row g-3">

        @* ── Personal Information ── *@
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header"><i class="fas fa-user me-1"></i> Personal Information</div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-3">
                            <label asp-for="EmployeeNo" class="form-label">
                                Employee No.
                            </label>
                            <input asp-for="EmployeeNo" class="form-control @(ViewData.ModelState["EmployeeNo"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   placeholder="e.g. EMP-0006" />
                            <div class="form-text">Leave blank to auto-generate.</div>
                            <span asp-validation-for="EmployeeNo" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="FirstName" class="form-label">
                                First Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="FirstName"
                                   class="form-control @(ViewData.ModelState["FirstName"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors ? "is-valid" : ""))" />
                            <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="MiddleName" class="form-label">Middle Name</label>
                            <input asp-for="MiddleName" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="LastName" class="form-label">
                                Last Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="LastName"
                                   class="form-control @(ViewData.ModelState["LastName"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors ? "is-valid" : ""))" />
                            <span asp-validation-for="LastName" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-2">
                            <label asp-for="Suffix" class="form-label">Suffix</label>
                            <input asp-for="Suffix" class="form-control" placeholder="Jr., Sr., III" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DateOfBirth" class="form-label">
                                Date of Birth <span class="text-danger">*</span>
                            </label>
                            <input asp-for="DateOfBirth" type="date"
                                   class="form-control @(ViewData.ModelState["DateOfBirth"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors ? "is-valid" : ""))"
                                   value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DateOfBirth" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Gender" class="form-label">
                                Gender <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Gender"
                                    class="form-select @(ViewData.ModelState["Gender"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && !string.IsNullOrEmpty(Model.Gender) ? "is-valid" : ""))">
                                <option value="">— Select —</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <span asp-validation-for="Gender" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CivilStatus" class="form-label">Civil Status</label>
                            <select asp-for="CivilStatus" class="form-select">
                                <option value="">— Select —</option>
                                <option value="Single">Single</option>
                                <option value="Married">Married</option>
                                <option value="Widowed">Widowed</option>
                                <option value="Separated">Separated</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Nationality" class="form-label">Nationality</label>
                            <input asp-for="Nationality" class="form-control" />
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Address" class="form-label">Address</label>
                            <input asp-for="Address" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                            <div class="masked-input-wrap">
                                <div class="mask-ghost" data-mask="09XXXXXXXXX"></div>
                                <input asp-for="ContactNumber"
                                       class="form-control masked-input @(ViewData.ModelState["ContactNumber"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                       maxlength="11"
                                       autocomplete="off" />
                            </div>
                            <span asp-validation-for="ContactNumber" class="invalid-feedback"></span>
                            <div class="form-text">Optional. Format: 09XXXXXXXXX</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PersonalEmail" class="form-label">Personal Email</label>
                            <input asp-for="PersonalEmail" type="email"
                                   class="form-control @(ViewData.ModelState["PersonalEmail"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                            <span asp-validation-for="PersonalEmail" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CompanyEmail" class="form-label">Company Email</label>
                            <input asp-for="CompanyEmail" type="email"
                                   class="form-control @(ViewData.ModelState["CompanyEmail"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                            <span asp-validation-for="CompanyEmail" class="invalid-feedback"></span>
                        </div>

                    </div>
                </div>
            </div>

            @* ── Government IDs ── *@
            <div class="card mb-3">
                <div class="card-header">
                    <i class="fas fa-id-card me-1"></i> Government IDs
                    <span class="text-danger ms-1">*</span>
                    <span class="text-muted ms-2" style="font-size:0.78rem;font-weight:400;">
                        All required — must match the correct format
                    </span>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-3">
                            <label asp-for="SSSNumber" class="form-label">SSS Number <span class="text-danger">*</span></label>
                            <div class="masked-input-wrap">
                                <div class="mask-ghost" data-mask="XX-XXXXXXX-X"></div>
                                <input asp-for="SSSNumber"
                                       class="form-control masked-input @(ViewData.ModelState["SSSNumber"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && !string.IsNullOrEmpty(Model.SSSNumber) ? "is-valid" : ""))"
                                       autocomplete="off" />
                            </div>
                            <span asp-validation-for="SSSNumber" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="PhilHealthNumber" class="form-label">PhilHealth No. <span class="text-danger">*</span></label>
                            <div class="masked-input-wrap">
                                <div class="mask-ghost" data-mask="XX-XXXXXXXXX-X"></div>
                                <input asp-for="PhilHealthNumber"
                                       class="form-control masked-input @(ViewData.ModelState["PhilHealthNumber"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && !string.IsNullOrEmpty(Model.PhilHealthNumber) ? "is-valid" : ""))"
                                       autocomplete="off" />
                            </div>
                            <span asp-validation-for="PhilHealthNumber" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="PagIbigNumber" class="form-label">Pag-IBIG No. <span class="text-danger">*</span></label>
                            <div class="masked-input-wrap">
                                <div class="mask-ghost" data-mask="XXXX-XXXX-XXXX"></div>
                                <input asp-for="PagIbigNumber"
                                       class="form-control masked-input @(ViewData.ModelState["PagIbigNumber"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && !string.IsNullOrEmpty(Model.PagIbigNumber) ? "is-valid" : ""))"
                                       autocomplete="off" />
                            </div>
                            <span asp-validation-for="PagIbigNumber" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="TINNumber" class="form-label">TIN Number <span class="text-danger">*</span></label>
                            <div class="masked-input-wrap">
                                <div class="mask-ghost" data-mask="XXX-XXX-XXX-XXX"></div>
                                <input asp-for="TINNumber"
                                       class="form-control masked-input @(ViewData.ModelState["TINNumber"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && !string.IsNullOrEmpty(Model.TINNumber) ? "is-valid" : ""))"
                                       autocomplete="off" />
                            </div>
                            <span asp-validation-for="TINNumber" class="invalid-feedback"></span>
                        </div>

                    </div>
                </div>
            </div>

            @* ── Employment Information ── *@
            <div class="card mb-3">
                <div class="card-header"><i class="fas fa-briefcase me-1"></i> Employment Information</div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-4">
                            <label asp-for="DepartmentID" class="form-label">
                                Department <span class="text-danger">*</span>
                            </label>
                            <select asp-for="DepartmentID" asp-items="Model.Departments"
                                    class="form-select @(ViewData.ModelState["DepartmentID"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && Model.DepartmentID > 0 ? "is-valid" : ""))"
                                    id="departmentSelect">
                                <option value="">— Select Department —</option>
                            </select>
                            <span asp-validation-for="DepartmentID" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PositionID" class="form-label">
                                Position <span class="text-danger">*</span>
                            </label>
                            <select asp-for="PositionID" class="form-select @(ViewData.ModelState["PositionID"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors && Model.PositionID > 0 ? "is-valid" : ""))"
                                    id="positionSelect">
                                <option value="">— Select Department first —</option>
                            </select>
                            <span asp-validation-for="PositionID" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Basic Salary</label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input type="text" id="salaryDisplay" class="form-control" readonly
                                       placeholder="Auto-filled from position" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DateHired" class="form-label">
                                Date Hired <span class="text-danger">*</span>
                            </label>
                            <input asp-for="DateHired" type="date"
                                   class="form-control @(ViewData.ModelState["DateHired"]?.Errors.Count > 0 ? "is-invalid" : (hasErrors ? "is-valid" : ""))"
                                   value="@Model.DateHired.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DateHired" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DateRegularized" class="form-label">Date Regularized</label>
                            <input asp-for="DateRegularized" type="date"
                                   class="form-control @(ViewData.ModelState["DateRegularized"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   value="@(Model.DateRegularized.HasValue ? Model.DateRegularized.Value.ToString("yyyy-MM-dd") : "")" />
                            <span asp-validation-for="DateRegularized" class="invalid-feedback"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="EmploymentStatus" class="form-label">
                                Employment Status <span class="text-danger">*</span>
                            </label>
                            <select asp-for="EmploymentStatus" class="form-select">
                                <option value="Regular">Regular</option>
                                <option value="Probationary">Probationary</option>
                                <option value="Contractual">Contractual</option>
                                <option value="Part-time">Part-time</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label">
                                Status <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        @* ── Right sidebar ── *@
        <div class="col-lg-4">
            <div class="card mb-3 border-0" style="background:#f8f9fa;">
                <div class="card-header border-0" style="background:#f8f9fa;">
                    <i class="fas fa-info-circle me-1 text-primary"></i> Quick Guide
                </div>
                <div class="card-body pt-0" style="font-size:0.82rem;">
                    <ul class="mb-0 ps-3 text-muted">
                        <li>Fields marked <span class="text-danger fw-bold">*</span> are required.</li>
                        <li>Employee No. is auto-generated if left blank.</li>
                        <li>Government IDs are required and must match the correct format.</li>
                        <li>Select Department first to load available positions.</li>
                        <li>Basic salary is auto-filled from the selected position.</li>
                        <li>Leave credits are automatically allocated on save.</li>
                    </ul>
                </div>
            </div>

            @if (hasErrors)
            {
                <div class="card border-danger mb-3">
                    <div class="card-header bg-danger text-white" style="font-size:0.85rem;">
                        <i class="fas fa-times-circle me-1"></i>
                        @ViewData.ModelState.Values.Sum(v => v.Errors.Count) error(s) found
                    </div>
                    <div class="card-body p-2" style="font-size:0.8rem;">
                        <ul class="mb-0 ps-3 text-danger">
                            @foreach (var entry in ViewData.ModelState)
                            {
                                foreach (var error in entry.Value!.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

    </div>

    <div class="d-flex gap-2 mb-4">
        <button type="submit" class="btn btn-pecci-primary">
            <i class="fas fa-save me-1"></i> Save Employee
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times me-1"></i> Cancel
        </a>
    </div>
</form>

<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Styles {
<style>
    /* ── Masked input ghost overlay ─────────────────────────────────────── */
    .masked-input-wrap {
        position: relative;
    }

    /* The ghost sits behind the real input, perfectly aligned */
    .mask-ghost {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        display: flex;
        align-items: center;
        padding: 0.375rem 0.75rem;          /* matches Bootstrap .form-control */
        font-size: 1rem;
        font-family: inherit;
        letter-spacing: inherit;
        pointer-events: none;
        white-space: pre;
        overflow: hidden;
        border-radius: var(--bs-border-radius, 0.375rem);
        z-index: 0;
    }

    /* Typed portion — invisible (transparent) so the real input text shows */
    .mask-ghost .ghost-typed {
        color: transparent;
    }

    /* Remaining portion — muted, visible */
    .mask-ghost .ghost-remaining {
        color: rgba(128, 128, 128, 0.55);
    }

    /* Real input sits on top, background transparent so ghost shows through */
    .masked-input-wrap .masked-input {
        position: relative;
        z-index: 1;
        background: transparent !important;
    }

    /* Keep the Bootstrap border/focus styles working */
    .masked-input-wrap .masked-input:focus {
        background: transparent !important;
    }
</style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script src="https://cdn.jsdelivr.net/npm/cleave.js@1.6.0/dist/cleave.min.js"></script>
<script>
    // ── Ghost overlay logic ─────────────────────────────────────────────────
    // For each .masked-input-wrap, keep the full mask pattern visible.
    // Typed characters make the corresponding ghost chars transparent;
    // untyped chars remain visible in a muted colour.
    function updateGhost(input) {
        const wrap = input.closest('.masked-input-wrap');
        if (!wrap) return;
        const ghost = wrap.querySelector('.mask-ghost');
        if (!ghost) return;

        const mask   = ghost.dataset.mask;   // e.g. "XX-XXXXXXX-X"
        const typed  = input.value;          // Cleave-formatted value
        const tLen   = typed.length;

        // Build two spans: transparent (typed length) + muted (rest)
        const typedPart     = mask.slice(0, tLen);
        const remainingPart = mask.slice(tLen);

        ghost.innerHTML =
            `<span class="ghost-typed">${typedPart}</span>` +
            `<span class="ghost-remaining">${remainingPart}</span>`;
    }

    // Initialise all ghost overlays on page load
    document.querySelectorAll('.masked-input-wrap').forEach(wrap => {
        const input = wrap.querySelector('.masked-input');
        const ghost = wrap.querySelector('.mask-ghost');
        if (!input || !ghost) return;
        // Set initial ghost to full mask
        ghost.innerHTML = `<span class="ghost-typed"></span><span class="ghost-remaining">${ghost.dataset.mask}</span>`;
        // Update on every keystroke (Cleave fires 'input' after formatting)
        input.addEventListener('input', () => updateGhost(input));
        // Also update if field has a value on load (validation round-trip)
        if (input.value) updateGhost(input);
    });

    // ── Cleave.js masks ─────────────────────────────────────────────────────
    new Cleave('#ContactNumber', {
        numericOnly: true, blocks: [11], delimiter: '',
        onValueChanged: () => updateGhost(document.getElementById('ContactNumber'))
    });
    new Cleave('#SSSNumber', {
        numericOnly: true, blocks: [2, 7, 1], delimiter: '-',
        onValueChanged: () => updateGhost(document.getElementById('SSSNumber'))
    });
    new Cleave('#PhilHealthNumber', {
        numericOnly: true, blocks: [2, 9, 1], delimiter: '-',
        onValueChanged: () => updateGhost(document.getElementById('PhilHealthNumber'))
    });
    new Cleave('#PagIbigNumber', {
        numericOnly: true, blocks: [4, 4, 4], delimiter: '-',
        onValueChanged: () => updateGhost(document.getElementById('PagIbigNumber'))
    });
    new Cleave('#TINNumber', {
        numericOnly: true, blocks: [3, 3, 3, 3], delimiter: '-',
        onValueChanged: () => updateGhost(document.getElementById('TINNumber'))
    });

    // ── Department → Position cascade ──────────────────────────────────────
    const deptSelect = document.getElementById('departmentSelect');
    const posSelect  = document.getElementById('positionSelect');

    const preselectedDept = deptSelect.value;
    const preselectedPos  = '@Model.PositionID';

    if (preselectedDept) {
        loadPositions(preselectedDept, preselectedPos);
    }

    deptSelect.addEventListener('change', function () {
        document.getElementById('salaryDisplay').value = '';
        loadPositions(this.value, null);
    });

    async function loadPositions(deptId, selectPositionId) {
        if (!deptId) {
            posSelect.innerHTML = '<option value="">— Select Department first —</option>';
            return;
        }
        posSelect.innerHTML = '<option value="">Loading…</option>';
        const res = await fetch(`/Employee/GetPositionsByDepartment?departmentId=${deptId}`);
        const positions = await res.json();

        posSelect.innerHTML = '<option value="">— Select Position —</option>';
        positions.forEach(p => {
            const selected = selectPositionId && p.positionID == selectPositionId ? 'selected' : '';
            posSelect.innerHTML +=
                `<option value="${p.positionID}" data-salary="${p.basicSalary}" ${selected}>${p.positionTitle}</option>`;
        });

        if (selectPositionId) updateSalary();
    }

    posSelect.addEventListener('change', updateSalary);

    function updateSalary() {
        const opt = posSelect.options[posSelect.selectedIndex];
        const salary = opt?.dataset?.salary;
        document.getElementById('salaryDisplay').value = salary
            ? parseFloat(salary).toLocaleString('en-PH', { minimumFractionDigits: 2 })
            : '';
    }

    // ── Scroll to validation banner on load if errors exist ────────────────
    const banner = document.getElementById('validationBanner');
    if (banner) {
        banner.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>
}
