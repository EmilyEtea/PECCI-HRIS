@model IEnumerable<PECCI_HRIS.Models.Employee>
@{
    ViewData["Title"] = "Employees";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHR = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-users me-2"></i>Employees</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Employees</li>
            </ol>
        </nav>
    </div>
    @if (isHR)
    {
        <a asp-action="Create" class="btn btn-pecci-primary">
            <i class="fas fa-plus me-1"></i> Add Employee
        </a>
    }
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small mb-1">Search</label>
                <input type="text" name="search" class="form-control form-control-sm"
                       placeholder="Name or Employee No." value="@ViewBag.Search" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Department</label>
                <select name="departmentId" class="form-select form-select-sm">
                    <option value="">All Departments</option>
                    @foreach (var dept in (List<PECCI_HRIS.Models.Department>)ViewBag.Departments)
                    {
                        <option value="@dept.DepartmentID" selected="@(ViewBag.DepartmentId?.ToString() == dept.DepartmentID.ToString())">
                            @dept.DepartmentName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
                    <option value="Inactive" selected="@(ViewBag.Status == "Inactive")">Inactive</option>
                    <option value="Resigned" selected="@(ViewBag.Status == "Resigned")">Resigned</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-pecci-primary btn-sm w-100">
                    <i class="fas fa-search me-1"></i> Search
                </button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-header">
        <i class="fas fa-list me-1"></i> Employee List
        <span class="badge ms-2" style="background:var(--pecci-green);">@Model.Count() records</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-pecci mb-0">
                <thead>
                    <tr>
                        <th>Employee No.</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Date Hired</th>
                        <th>Employment</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        <tr>
                            <td><span class="fw-semibold text-success">@emp.EmployeeNo</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar" style="width:32px;height:32px;border-radius:50%;background:var(--pecci-green-pale);color:var(--pecci-green);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;flex-shrink:0;">
                                        @(emp.FirstName.FirstOrDefault())@(emp.LastName.FirstOrDefault())
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@emp.FullName</div>
                                        <div class="text-muted small">@emp.CompanyEmail</div>
                                    </div>
                                </div>
                            </td>
                            <td>@emp.Department?.DepartmentName</td>
                            <td>@emp.Position?.PositionTitle</td>
                            <td>@emp.DateHired.ToString("MM/dd/yyyy")</td>
                            <td><span class="status-badge badge-present">@emp.EmploymentStatus</span></td>
                            <td>
                                @{
                                    var sc = emp.Status == "Active" ? "badge-active" : "badge-inactive";
                                }
                                <span class="status-badge @sc">@emp.Status</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Profile" asp-route-id="@emp.EmployeeID"
                                       class="btn btn-sm btn-outline-success" title="View Profile">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (isHR)
                                    {
                                        <a asp-action="Edit" asp-route-id="@emp.EmployeeID"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (emp.Status == "Active")
                                        {
                                            <button class="btn btn-sm btn-outline-danger" title="Deactivate"
                                                    onclick="confirmDeactivate(@emp.EmployeeID, '@emp.FullName')">
                                                <i class="fas fa-user-slash"></i>
                                            </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fas fa-users fa-2x mb-2 d-block opacity-25"></i>
                                No employees found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Deactivate Modal -->
<div class="modal fade" id="deactivateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:var(--pecci-danger);color:white;">
                <h5 class="modal-title"><i class="fas fa-user-slash me-2"></i>Deactivate Employee</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Deactivate" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p>Are you sure you want to deactivate <strong id="empName"></strong>?</p>
                    <input type="hidden" name="id" id="deactivateId" />
                    <div class="mb-3">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <input type="text" name="reason" class="form-control" required
                               placeholder="e.g. Resigned, Terminated, Retired" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-pecci-danger">Deactivate</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Credits -->
<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
<script>
    function confirmDeactivate(id, name) {
        document.getElementById('deactivateId').value = id;
        document.getElementById('empName').textContent = name;
        new bootstrap.Modal(document.getElementById('deactivateModal')).show();
    }
</script>
}
