@model IEnumerable<PECCI_HRIS.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Trail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-history me-2"></i>Audit Trail</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Audit Trail</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">Module</label>
                <select name="module" class="form-select form-select-sm">
                    <option value="">All Modules</option>
                    @foreach (var mod in new[] { "Employee", "Department", "Position", "Leave", "Payroll", "Attendance", "Users", "Settings", "Account" })
                    {
                        <option value="@mod" selected="@(ViewBag.Module == mod)">@mod</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Action</label>
                <input type="text" name="action" class="form-control form-control-sm"
                       placeholder="e.g. Login, Create" value="@ViewBag.Action" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Username</label>
                <input type="text" name="username" class="form-control form-control-sm"
                       placeholder="Username" value="@ViewBag.Username" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Date From</label>
                <input type="date" name="dateFrom" class="form-control form-control-sm" value="@ViewBag.DateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Date To</label>
                <input type="date" name="dateTo" class="form-control form-control-sm" value="@ViewBag.DateTo" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-pecci-primary btn-sm w-100">
                    <i class="fas fa-search"></i>
                </button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100" title="Clear">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-list me-1"></i> Audit Log
        <span class="badge ms-2" style="background:var(--pecci-green);">@Model.Count() records</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-pecci mb-0 table-sm">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Username</th>
                        <th>Action</th>
                        <th>Module</th>
                        <th>Description</th>
                        <th>IP Address</th>
                        <th>Old Values</th>
                        <th>New Values</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        var rowStyle = log.Action?.ToLower() switch {
                            var a when a != null && a.Contains("login")  => "background:#e8f5e9;",
                            var a when a != null && a.Contains("delete") => "background:#ffebee;",
                            var a when a != null && a.Contains("update") => "background:#fffde7;",
                            var a when a != null && a.Contains("edit")   => "background:#fffde7;",
                            _ => ""
                        };
                        <tr style="@rowStyle">
                            <td class="small text-nowrap">@log.Timestamp.ToString("MM/dd/yyyy HH:mm:ss")</td>
                            <td>
                                <span class="fw-semibold small">@log.Username</span>
                            </td>
                            <td>
                                @{
                                    var actionColor = log.Action?.ToLower() switch {
                                        var a when a != null && a.Contains("login")  => "text-success",
                                        var a when a != null && a.Contains("delete") => "text-danger",
                                        var a when a != null && a.Contains("create") => "text-primary",
                                        _ => "text-warning"
                                    };
                                }
                                <span class="small fw-semibold @actionColor">@log.Action</span>
                            </td>
                            <td>
                                <span class="badge" style="background:var(--pecci-green-pale);color:var(--pecci-green);font-size:0.7rem;">
                                    @log.Module
                                </span>
                            </td>
                            <td class="small text-muted" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                title="@log.Description">
                                @log.Description
                            </td>
                            <td class="small text-muted">@log.IPAddress</td>
                            <td class="small text-muted" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                title="@log.OldValues">
                                @(string.IsNullOrEmpty(log.OldValues) ? "—" : (log.OldValues.Length > 40 ? log.OldValues[..40] + "…" : log.OldValues))
                            </td>
                            <td class="small text-muted" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                title="@log.NewValues">
                                @(string.IsNullOrEmpty(log.NewValues) ? "—" : (log.NewValues.Length > 40 ? log.NewValues[..40] + "…" : log.NewValues))
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fas fa-history fa-2x mb-2 d-block opacity-25"></i>
                                No audit log entries found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
