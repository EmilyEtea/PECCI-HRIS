@model PECCI_HRIS.Models.Position
@{
    ViewData["Title"] = "Add Position";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-briefcase me-2"></i>Add Position</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Positions</a></li>
                <li class="breadcrumb-item active">Add Position</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-plus me-1"></i> New Position
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="PositionTitle" class="form-label fw-semibold">
                            Position Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="PositionTitle" class="form-control" placeholder="e.g. Senior Accountant" />
                        <span asp-validation-for="PositionTitle" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PositionCode" class="form-label fw-semibold">Position Code</label>
                        <input asp-for="PositionCode" class="form-control" placeholder="e.g. ACCT-SR" maxlength="20" />
                        <span asp-validation-for="PositionCode" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DepartmentID" class="form-label fw-semibold">
                            Department <span class="text-danger">*</span>
                        </label>
                        <select asp-for="DepartmentID" asp-items="ViewBag.Departments" class="form-select">
                            <option value="">— Select Department —</option>
                        </select>
                        <span asp-validation-for="DepartmentID" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BasicSalary" class="form-label fw-semibold">Basic Salary</label>
                        <div class="input-group">
                            <span class="input-group-text fw-bold" style="color:var(--pecci-green);">₱</span>
                            <input asp-for="BasicSalary" class="form-control" type="number" step="0.01" min="0"
                                   placeholder="0.00" />
                        </div>
                        <span asp-validation-for="BasicSalary" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Brief description of this position..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-pecci-primary">
                            <i class="fas fa-save me-1"></i> Save Position
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
