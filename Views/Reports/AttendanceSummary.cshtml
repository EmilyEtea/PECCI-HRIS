@model dynamic
@{
    ViewData["Title"] = "Attendance Summary Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header no-print">
    <div>
        <h1><i class="fas fa-calendar-check me-2"></i>Attendance Summary Report</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
                <li class="breadcrumb-item active">Attendance Summary</li>
            </ol>
        </nav>
    </div>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print">
        <i class="fas fa-print me-1"></i> Print Report
    </button>
</div>

<!-- Filters -->
<div class="card mb-3 no-print">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">Month</label>
                <select name="month" class="form-select form-select-sm">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(ViewBag.Month?.ToString() == m.ToString())">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Year</label>
                <input type="number" name="year" class="form-control form-control-sm"
                       value="@(ViewBag.Year ?? DateTime.Today.Year)" min="2020" max="2099" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Department</label>
                <select name="departmentId" class="form-select form-select-sm">
                    <option value="">All Departments</option>
                    @if (ViewBag.Departments != null)
                    {
                        foreach (var dept in (List<PECCI_HRIS.Models.Department>)ViewBag.Departments)
                        {
                            <option value="@dept.DepartmentID" selected="@(ViewBag.DepartmentId?.ToString() == dept.DepartmentID.ToString())">
                                @dept.DepartmentName
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-pecci-primary btn-sm w-100">
                    <i class="fas fa-search me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Print Header -->
<div class="text-center mb-3 print-only" style="display:none;">
    <h4 class="fw-bold">PLDT Employees Credit Cooperative, Inc.</h4>
    <h5>Attendance Summary Report</h5>
    <div class="text-muted small">Generated: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")</div>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-list me-1"></i> Attendance Summary
        <span class="text-muted small ms-2">@(ViewBag.PeriodLabel ?? "")</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-pecci mb-0 table-sm">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th class="text-center">Present</th>
                        <th class="text-center">Late</th>
                        <th class="text-center">Absent</th>
                        <th class="text-center">On Leave</th>
                        <th class="text-center">Late Time</th>
                        <th class="text-center">Overtime</th>
                        <th class="text-center">Total Hours</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int totalPresent = 0, totalLate = 0, totalAbsent = 0, totalOnLeave = 0;
                        double totalLateMin = 0, totalOTMin = 0, totalHours = 0;
                    }
                    @if (Model != null)
                    {
                        foreach (var row in Model)
                        {
                            totalPresent  += (int)row.TotalPresent;
                            totalLate     += (int)row.TotalLate;
                            totalAbsent   += (int)row.TotalAbsent;
                            totalOnLeave  += (int)row.TotalOnLeave;
                            totalLateMin  += (double)row.TotalLateMinutes;
                            totalOTMin    += (double)row.TotalOvertimeMinutes;
                            totalHours    += (double)row.TotalHoursWorked;
                            <tr>
                                <td>
                                    <div class="fw-semibold">@row.Employee.FullName</div>
                                    <div class="text-muted" style="font-size:0.7rem;">@row.Employee.EmployeeNo</div>
                                </td>
                                <td class="small">@row.Employee.Department?.DepartmentName</td>
                                <td class="text-center text-success fw-semibold">@row.TotalPresent</td>
                                <td class="text-center text-warning fw-semibold">@row.TotalLate</td>
                                <td class="text-center text-danger fw-semibold">@row.TotalAbsent</td>
                                <td class="text-center">@row.TotalOnLeave</td>
                                <td class="text-center small @(row.TotalLateMinutes > 0 ? "text-danger" : "")">@row.LateMinutesDisplay</td>
                                <td class="text-center small @(row.TotalOvertimeMinutes > 0 ? "text-success" : "")">@row.OvertimeDisplay</td>
                                <td class="text-center fw-semibold">@row.TotalHoursWorked.ToString("F2")</td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot>
                    <tr style="background:var(--pecci-green-pale);font-weight:700;border-top:2px solid var(--pecci-green);">
                        <td colspan="2">Totals</td>
                        <td class="text-center text-success">@totalPresent</td>
                        <td class="text-center text-warning">@totalLate</td>
                        <td class="text-center text-danger">@totalAbsent</td>
                        <td class="text-center">@totalOnLeave</td>
                        <td class="text-center small">
                            @(totalLateMin >= 60 ? $"{(int)(totalLateMin/60)}h {(int)(totalLateMin%60)}m" : $"{(int)totalLateMin}m")
                        </td>
                        <td class="text-center small">
                            @(totalOTMin >= 60 ? $"{(int)(totalOTMin/60)}h {(int)(totalOTMin%60)}m" : $"{(int)totalOTMin}m")
                        </td>
                        <td class="text-center">@totalHours.ToString("F2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
