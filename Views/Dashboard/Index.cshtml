@model PECCI_HRIS.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var today = DateTime.Today;
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item active">@today.ToString("dddd, MMMM dd, yyyy")</li>
            </ol>
        </nav>
    </div>
</div>

<!-- ── Stat Cards ──────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card green">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div class="stat-value">@Model.TotalEmployees</div>
            <div class="stat-label">Active Employees</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card teal">
            <div class="stat-icon"><i class="fas fa-user-check"></i></div>
            <div class="stat-value">@Model.PresentToday</div>
            <div class="stat-label">Present Today</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card orange">
            <div class="stat-icon"><i class="fas fa-user-clock"></i></div>
            <div class="stat-value">@Model.LateToday</div>
            <div class="stat-label">Late Today</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card blue">
            <div class="stat-icon"><i class="fas fa-calendar-minus"></i></div>
            <div class="stat-value">@Model.OnLeaveToday</div>
            <div class="stat-label">On Leave Today</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card red">
            <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
            <div class="stat-value">@Model.PendingLeaves</div>
            <div class="stat-label">Pending Leaves</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card gold">
            <div class="stat-icon"><i class="fas fa-building"></i></div>
            <div class="stat-value">@Model.TotalDepartments</div>
            <div class="stat-label">Departments</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Attendance Donut -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-chart-pie me-1"></i> Today's Attendance
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <canvas id="attendanceChart" width="200" height="200"></canvas>
                <div class="mt-3 w-100">
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-success me-1">&nbsp;</span>Present</span>
                        <strong>@Model.AttendanceSummary.Present</strong>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-warning me-1">&nbsp;</span>Late</span>
                        <strong>@Model.AttendanceSummary.Late</strong>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-danger me-1">&nbsp;</span>Absent</span>
                        <strong>@Model.AttendanceSummary.Absent</strong>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-info me-1">&nbsp;</span>On Leave</span>
                        <strong>@Model.AttendanceSummary.OnLeave</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-history me-1"></i> Recent Activity
            </div>
            <div class="card-body p-0" style="overflow-y:auto;max-height:320px;">
                <table class="table table-sm mb-0">
                    <tbody>
                        @foreach (var a in Model.RecentActivities)
                        {
                            <tr>
                                <td class="ps-3 py-2" style="width:32px;">
                                    @{
                                        var icon = a.Action switch {
                                            "Login"  => "fa-sign-in-alt text-success",
                                            "Logout" => "fa-sign-out-alt text-muted",
                                            "TimeIn" => "fa-clock text-primary",
                                            "TimeOut"=> "fa-clock text-secondary",
                                            "Update" => "fa-edit text-warning",
                                            "Create" => "fa-plus text-success",
                                            "Delete" => "fa-trash text-danger",
                                            _ => "fa-circle text-muted"
                                        };
                                    }
                                    <i class="fas @icon"></i>
                                </td>
                                <td class="py-2">
                                    <div class="small fw-semibold">@a.Username <span class="text-muted fw-normal">— @a.Module</span></div>
                                    <div class="text-muted" style="font-size:0.72rem;">@a.Description</div>
                                </td>
                                <td class="pe-3 py-2 text-muted text-end" style="font-size:0.7rem;white-space:nowrap;">
                                    @a.Timestamp.ToString("MM/dd HH:mm")
                                </td>
                            </tr>
                        }
                        @if (!Model.RecentActivities.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">No recent activity</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Upcoming Birthdays -->
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-birthday-cake me-1"></i> Upcoming Birthdays
            </div>
            <div class="card-body p-0">
                @if (Model.UpcomingBirthdays.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var b in Model.UpcomingBirthdays)
                        {
                            <li class="list-group-item py-2 px-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:36px;height:36px;border-radius:50%;background:var(--pecci-gold);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;">
                                        🎂
                                    </div>
                                    <div>
                                        <div class="small fw-semibold">@b.EmployeeName</div>
                                        <div class="text-muted" style="font-size:0.72rem;">
                                            @b.Department &bull; @b.BirthDate.ToString("MMMM dd")
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center text-muted py-4 small">No birthdays in the next 7 days</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Credits Footer -->
<div class="mt-4 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
    &mdash; PECCI HRIS v1.0.0
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
    const ctx = document.getElementById('attendanceChart').getContext('2d');
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Present', 'Late', 'Absent', 'On Leave'],
            datasets: [{
                data: [@Model.AttendanceSummary.Present, @Model.AttendanceSummary.Late,
                       @Model.AttendanceSummary.Absent, @Model.AttendanceSummary.OnLeave],
                backgroundColor: ['#28a745','#ffc107','#dc3545','#17a2b8'],
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            cutout: '65%',
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw}` } }
            }
        }
    });
</script>
}
