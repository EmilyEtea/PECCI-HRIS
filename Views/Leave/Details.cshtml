@model PECCI_HRIS.Models.LeaveApplication
@{
    ViewData["Title"] = "Leave Application Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHR       = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
    var isManager  = User.IsInRole("Manager");
    var badgeClass = Model.Status switch {
        "Approved"   => "badge-approved",
        "Rejected"   => "badge-rejected",
        "Cancelled"  => "badge-inactive",
        "Pending HR" => "badge-pending",
        _            => "badge-pending"
    };
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-file-alt me-2"></i>Leave Application Details</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Leave Applications</a></li>
                <li class="breadcrumb-item active">#@Model.LeaveApplicationID</li>
            </ol>
        </nav>
    </div>
    <span class="status-badge @badgeClass" style="font-size:0.9rem;padding:0.4rem 1rem;">
        @Model.Status
    </span>
</div>

<div class="row g-3">

    @* ── Application Details ── *@
    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header">
                <i class="fas fa-info-circle me-1"></i> Application Details
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @if (isHR || isManager)
                    {
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Employee</div>
                            <div class="fw-semibold">@Model.Employee?.FullName</div>
                            <div class="text-muted small">
                                @Model.Employee?.Department?.DepartmentName
                                @if (Model.Employee?.Position != null)
                                {
                                    <span>— @Model.Employee.Position.PositionTitle</span>
                                }
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Leave Type</div>
                        <div class="fw-semibold">@Model.LeaveType?.LeaveTypeName</div>
                        @if (!string.IsNullOrEmpty(Model.LeaveType?.LeaveCode))
                        {
                            <span class="badge" style="background:var(--pecci-green-pale);color:var(--pecci-green);">
                                @Model.LeaveType.LeaveCode
                            </span>
                        }
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small mb-1">Start Date</div>
                        <div class="fw-semibold">@Model.StartDate.ToString("MMMM dd, yyyy")</div>
                        <div class="text-muted small">@Model.StartDate.ToString("dddd")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small mb-1">End Date</div>
                        <div class="fw-semibold">@Model.EndDate.ToString("MMMM dd, yyyy")</div>
                        <div class="text-muted small">@Model.EndDate.ToString("dddd")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small mb-1">Duration</div>
                        <div class="fw-bold fs-5" style="color:var(--pecci-green);">
                            @Model.NumberOfDays day(s)
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small mb-1">Reason</div>
                        <div class="p-3 rounded" style="background:var(--pecci-bg-light);border:1px solid var(--pecci-border);">
                            @(string.IsNullOrEmpty(Model.Reason) ? "No reason provided." : Model.Reason)
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Applied On</div>
                        <div>@Model.AppliedAt.ToString("MMMM dd, yyyy hh:mm tt")</div>
                    </div>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Last Updated</div>
                            <div>@Model.UpdatedAt.Value.ToString("MMMM dd, yyyy hh:mm tt")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
        @if ((isHR || isManager) && (Model.Status == "Pending" || Model.Status == "Pending HR"))
        {
            <a asp-action="Review" asp-route-id="@Model.LeaveApplicationID"
               class="btn btn-pecci-primary ms-2">
                <i class="fas fa-clipboard-check me-1"></i> Review Application
            </a>
        }
    </div>

    @* ── Approval History & Remarks ── *@
    <div class="col-lg-5">

        @* Always show this card — even if no remarks yet, so the employee knows the section exists *@
        <div class="card">
            <div class="card-header">
                <i class="fas fa-comments me-1"></i> Approval Remarks
            </div>
            <div class="card-body">

                @* ── Manager decision ── *@
                @if (Model.ManagerApprovedAt.HasValue)
                {
                    <div class="mb-3 pb-3" style="border-bottom:1px solid var(--pecci-border);">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="fas fa-user-tie text-muted"></i>
                            <span class="fw-semibold small">Manager Review</span>
                            <span class="ms-auto text-muted" style="font-size:0.72rem;">
                                @Model.ManagerApprovedAt.Value.ToString("MM/dd/yyyy hh:mm tt")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ManagerRemarks))
                        {
                            <div class="p-2 rounded" style="background:var(--pecci-bg-light);border:1px solid var(--pecci-border);font-size:0.9rem;">
                                @Model.ManagerRemarks
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small fst-italic">No remarks left by manager.</div>
                        }
                    </div>
                }

                @* ── HR decision ── *@
                @if (Model.HRApprovedAt.HasValue)
                {
                    <div class="mb-2">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            @{
                                var hrDecisionColor = Model.Status == "Approved" ? "var(--pecci-green)" : "#dc3545";
                                var hrDecisionIcon  = Model.Status == "Approved" ? "fa-check-circle" : "fa-times-circle";
                            }
                            <i class="fas @hrDecisionIcon" style="color:@hrDecisionColor;"></i>
                            <span class="fw-semibold small">HR Decision</span>
                            <span class="status-badge @badgeClass ms-1" style="font-size:0.65rem;padding:0.1rem 0.5rem;">
                                @Model.Status
                            </span>
                            <span class="ms-auto text-muted" style="font-size:0.72rem;">
                                @Model.HRApprovedAt.Value.ToString("MM/dd/yyyy hh:mm tt")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.HRRemarks))
                        {
                            <div class="p-2 rounded" style="background:var(--pecci-bg-light);border:1px solid var(--pecci-border);font-size:0.9rem;">
                                @Model.HRRemarks
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small fst-italic">No remarks left by HR.</div>
                        }
                    </div>
                }

                @* ── Nothing yet ── *@
                @if (!Model.ManagerApprovedAt.HasValue && !Model.HRApprovedAt.HasValue)
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-clock fa-2x mb-2 d-block opacity-25"></i>
                        <div class="small">Awaiting review. Remarks will appear here once the application has been processed.</div>
                    </div>
                }

            </div>
        </div>
    </div>

</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
