@model IEnumerable<PECCI_HRIS.Models.LeaveCredit>
@{
    ViewData["Title"] = "Leave Credits";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHR = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
    // Group by employee for categorized display
    var grouped = Model.GroupBy(lc => lc.EmployeeID).ToList();
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-coins me-2"></i>Leave Credits</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Leave Credits</li>
            </ol>
        </nav>
    </div>
    @if (User.IsInRole("HR Admin"))
    {
        <form asp-action="RefreshCredits" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="year" value="@DateTime.Today.Year" />
            <button type="button" class="btn btn-outline-secondary btn-sm"
                    onclick="swalConfirm(this, 'This will allocate leave credits for all active employees for @DateTime.Today.Year.', 'Yes, refresh')">
                <i class="fas fa-sync-alt me-1"></i> Refresh Credits
            </button>
        </form>
    }
</div>

<!-- Filters (HR only) -->
@if (isHR)
{
    <div class="card mb-3">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Employee</label>
                    <select name="employeeId" class="form-select form-select-sm">
                        <option value="">All Employees</option>
                        @if (ViewBag.Employees != null)
                        {
                            foreach (var emp in (List<PECCI_HRIS.Models.Employee>)ViewBag.Employees)
                            {
                                <option value="@emp.EmployeeID"
                                        selected="@(ViewBag.EmployeeId?.ToString() == emp.EmployeeID.ToString())">
                                    @emp.FullName
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Year</label>
                    <input type="number" name="year" class="form-control form-control-sm"
                           value="@(ViewBag.Year ?? DateTime.Today.Year)" min="2020" max="2099" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-pecci-primary btn-sm w-100">
                        <i class="fas fa-search me-1"></i> Filter
                    </button>
                </div>
                <div class="col-md-1">
                    <a asp-action="Credits" class="btn btn-outline-secondary btn-sm w-100" title="Clear">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fas fa-coins fa-2x mb-2 d-block opacity-25"></i>
            No leave credits found.
        </div>
    </div>
}

@foreach (var group in grouped)
{
    var credits    = group.ToList();
    var employee   = credits.First().Employee;
    var totalUsed  = credits.Sum(c => c.UsedCredits);
    var totalLeft  = credits.Sum(c => c.RemainingCredits);
    var totalAlloc = credits.Sum(c => c.TotalCredits);

    <div class="card mb-3">
        <!-- Employee header -->
        <div class="card-header d-flex justify-content-between align-items-center"
             style="background:var(--pecci-green-pale);">
            <div class="d-flex align-items-center gap-3">
                <div style="width:40px;height:40px;border-radius:50%;background:var(--pecci-green);
                            color:white;display:flex;align-items:center;justify-content:center;
                            font-weight:700;font-size:0.9rem;flex-shrink:0;">
                    @(employee?.FirstName.FirstOrDefault())@(employee?.LastName.FirstOrDefault())
                </div>
                <div>
                    <div class="fw-bold" style="color:var(--pecci-green-dark);">@employee?.FullName</div>
                    <div class="text-muted small">
                        @employee?.EmployeeNo &bull; @employee?.Department?.DepartmentName
                    </div>
                </div>
            </div>
            <div class="text-end small">
                <div class="text-muted">Total Balance</div>
                <div class="fw-bold fs-6 @(totalLeft <= 0 ? "text-danger" : "text-success")">
                    @totalLeft.ToString("F1") days remaining
                </div>
            </div>
        </div>

        <!-- Leave type cards -->
        <div class="card-body">
            <div class="row g-3">
                @foreach (var credit in credits.OrderBy(c => c.LeaveType?.LeaveTypeName))
                {
                    var pct = credit.TotalCredits > 0
                        ? (double)credit.UsedCredits / (double)credit.TotalCredits * 100
                        : 0;
                    var barColor = credit.RemainingCredits <= 0 ? "var(--pecci-danger)"
                                 : credit.RemainingCredits <= 3 ? "var(--pecci-warning)"
                                 : "var(--pecci-green)";

                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded border h-100"
                             style="border-color:var(--pecci-border) !important;background:white;">
                            <!-- Leave type name + code badge -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="fw-semibold small">@credit.LeaveType?.LeaveTypeName</div>
                                @if (!string.IsNullOrEmpty(credit.LeaveType?.LeaveCode))
                                {
                                    <span class="badge"
                                          style="background:var(--pecci-green-pale);color:var(--pecci-green);font-size:0.65rem;">
                                        @credit.LeaveType.LeaveCode
                                    </span>
                                }
                            </div>

                            <!-- Progress bar -->
                            <div class="progress mb-2" style="height:6px;border-radius:3px;">
                                <div class="progress-bar" role="progressbar"
                                     style="width:@pct.ToString("F0")%;background:@barColor;border-radius:3px;">
                                </div>
                            </div>

                            <!-- Stats row -->
                            <div class="d-flex justify-content-between" style="font-size:0.75rem;">
                                <div class="text-center">
                                    <div class="text-muted">Total</div>
                                    <div class="fw-bold">@credit.TotalCredits</div>
                                </div>
                                <div class="text-center">
                                    <div class="text-muted">Used</div>
                                    <div class="fw-bold text-warning">@credit.UsedCredits</div>
                                </div>
                                @if (credit.PendingCredits > 0)
                                {
                                    <div class="text-center">
                                        <div class="text-muted">Pending</div>
                                        <div class="fw-bold text-info">@credit.PendingCredits</div>
                                    </div>
                                }
                                <div class="text-center">
                                    <div class="text-muted">Left</div>
                                    <div class="fw-bold @(credit.RemainingCredits <= 0 ? "text-danger" : "text-success")">
                                        @credit.RemainingCredits
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
