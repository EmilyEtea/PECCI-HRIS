@model IEnumerable<PECCI_HRIS.Models.LeaveApplication>
@{
    ViewData["Title"] = "Leave Applications";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHR = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
    var isManager = User.IsInRole("Manager");
    var isHROrManager = isHR || isManager;
    var empIdClaim = User.FindFirst("EmployeeID")?.Value ?? "0";
    int currentEmpId = int.Parse(empIdClaim);
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-calendar-minus me-2"></i>Leave Applications</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Leave Applications</li>
            </ol>
        </nav>
    </div>
    <a asp-action="Apply" class="btn btn-pecci-primary">
        <i class="fas fa-plus me-1"></i> Apply for Leave
    </a>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            @if (isHR)
            {
                <div class="col-md-3">
                    <label class="form-label small mb-1">Employee</label>
                    <select name="employeeId" class="form-select form-select-sm">
                        <option value="">All Employees</option>
                        @if (ViewBag.Employees != null)
                        {
                            foreach (var emp in (List<PECCI_HRIS.Models.Employee>)ViewBag.Employees)
                            {
                                <option value="@emp.EmployeeID" selected="@(ViewBag.EmployeeId?.ToString() == emp.EmployeeID.ToString())">
                                    @emp.FullName
                                </option>
                            }
                        }
                    </select>
                </div>
            }
            <div class="col-md-3">
                <label class="form-label small mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="Pending"  selected="@(ViewBag.Status == "Pending")">Pending</option>
                    <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                    <option value="Disapproved" selected="@(ViewBag.Status == "Disapproved")">Disapproved</option>
                    <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-pecci-primary btn-sm w-100">
                    <i class="fas fa-search me-1"></i> Filter
                </button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100" title="Clear">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-header">
        <i class="fas fa-list me-1"></i> Leave Applications
        <span class="badge ms-2" style="background:var(--pecci-green);">@Model.Count() records</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-pecci mb-0">
                <thead>
                    <tr>
                        @if (isHR) { <th>Employee</th> }
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="text-center">Days</th>
                        <th>Applied On</th>
                        <th class="text-center">Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        <tr>
                            @if (isHR)
                            {
                                <td>
                                    <div class="fw-semibold">@leave.Employee?.FullName</div>
                                    <div class="text-muted small">@leave.Employee?.Department?.DepartmentName</div>
                                </td>
                            }
                            <td>
                                <div class="fw-semibold">@leave.LeaveType?.LeaveTypeName</div>
                                @if (!string.IsNullOrEmpty(leave.LeaveType?.LeaveCode))
                                {
                                    <span class="badge" style="background:var(--pecci-green-pale);color:var(--pecci-green);font-size:0.7rem;">@leave.LeaveType.LeaveCode</span>
                                }
                            </td>
                            <td>@leave.StartDate.ToString("MM/dd/yyyy")</td>
                            <td>@leave.EndDate.ToString("MM/dd/yyyy")</td>
                            <td class="text-center fw-semibold">
                                @leave.NumberOfDays
                                @if (leave.IsHalfDay)
                                {
                                    <span class="badge bg-info text-dark d-block" style="font-size:0.6rem;">½ @leave.HalfDayPeriod</span>
                                }
                            </td>
                            <td class="text-muted small">@leave.AppliedAt.ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @{
                                    var badgeClass = leave.Status switch {
                                        "Approved"     => "badge-approved",
                                        "Disapproved"  => "badge-rejected",
                                        "Cancelled"    => "badge-inactive",
                                        _              => "badge-pending"
                                    };
                                }
                                <span class="status-badge @badgeClass">@leave.Status</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@leave.LeaveApplicationID"
                                       class="btn btn-sm btn-outline-secondary" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (isHROrManager && leave.Status == "Pending")
                                    {
                                        <a asp-action="Review" asp-route-id="@leave.LeaveApplicationID"
                                           class="btn btn-sm btn-pecci-primary" title="Review">
                                            <i class="fas fa-clipboard-check me-1"></i> Review
                                        </a>
                                    }
                                    @if (leave.EmployeeID == currentEmpId && leave.Status == "Pending")
                                    {
                                        <form asp-action="Cancel" asp-route-id="@leave.LeaveApplicationID" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="Cancel"
                                                    onclick="swalDanger(this, 'Your leave application will be cancelled.', 'Yes, cancel it')">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="fas fa-calendar-minus fa-2x mb-2 d-block opacity-25"></i>
                                No leave applications found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
