@model PECCI_HRIS.ViewModels.LeaveApplicationViewModel
@{
    ViewData["Title"] = "Apply for Leave";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-calendar-plus me-2"></i>Apply for Leave</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Leave Applications</a></li>
                <li class="breadcrumb-item active">Apply</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-file-alt me-1"></i> Leave Application Form
            </div>
            <div class="card-body">
                <form asp-action="Apply" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="LeaveApplicationID" type="hidden" />
                    <input asp-for="EmployeeID" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="LeaveTypeID" class="form-label fw-semibold">
                            Leave Type <span class="text-danger">*</span>
                        </label>
                        <select asp-for="LeaveTypeID" asp-items="Model.LeaveTypes" class="form-select" id="leaveTypeSelect">
                            <option value="">— Select Leave Type —</option>
                        </select>
                        <span asp-validation-for="LeaveTypeID" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-semibold">
                                Start Date <span class="text-danger">*</span>
                            </label>
                            <input asp-for="StartDate" class="form-control" type="date" id="startDate"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3" id="endDateGroup">
                            <label asp-for="EndDate" class="form-label fw-semibold">
                                End Date <span class="text-danger">*</span>
                            </label>
                            <input asp-for="EndDate" class="form-control" type="date" id="endDate"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Half-day toggle -->
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsHalfDay" class="form-check-input" type="checkbox"
                                   id="isHalfDay" role="switch" />
                            <label asp-for="IsHalfDay" class="form-check-label fw-semibold">
                                Half Day
                            </label>
                        </div>
                        <div id="halfDayPeriodGroup" style="display:none;" class="mt-2">
                            <label class="form-label small fw-semibold">Period</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input asp-for="HalfDayPeriod" class="form-check-input" type="radio"
                                           id="halfAM" value="AM" checked />
                                    <label class="form-check-label" for="halfAM">
                                        <i class="fas fa-sun me-1 text-warning"></i> AM (Morning)
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="HalfDayPeriod" class="form-check-input" type="radio"
                                           id="halfPM" value="PM" />
                                    <label class="form-check-label" for="halfPM">
                                        <i class="fas fa-moon me-1 text-primary"></i> PM (Afternoon)
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Live day count -->
                    <div class="alert alert-info py-2 mb-3" id="dayCountAlert" style="display:none;">
                        <i class="fas fa-info-circle me-1"></i>
                        Number of days: <strong id="dayCount">0</strong>
                        <span class="text-muted small ms-2" id="dayCountNote">(excluding weekends)</span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Reason" class="form-label fw-semibold">Reason</label>
                        <textarea asp-for="Reason" class="form-control" rows="4"
                                  placeholder="Please provide the reason for your leave request..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-pecci-primary">
                            <i class="fas fa-paper-plane me-1"></i> Submit Application
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-coins me-1"></i> My Leave Credits
            </div>
            <div class="card-body p-0">
                @if (Model.LeaveCredits.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-pecci mb-0 table-sm">
                            <thead>
                                <tr>
                                    <th>Leave Type</th>
                                    <th class="text-center">Total</th>
                                    <th class="text-center">Used</th>
                                    <th class="text-center">Remaining</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var credit in Model.LeaveCredits)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold small">@credit.LeaveType?.LeaveTypeName</div>
                                            <div class="text-muted" style="font-size:0.7rem;">@credit.Year</div>
                                        </td>
                                        <td class="text-center small">@credit.TotalCredits</td>
                                        <td class="text-center small">@credit.UsedCredits</td>
                                        <td class="text-center">
                                            <span class="fw-bold @(credit.RemainingCredits <= 0 ? "text-danger" : "text-success")">
                                                @credit.RemainingCredits
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-coins fa-2x mb-2 d-block opacity-25"></i>
                        No leave credits found for this year.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function countWorkdays(start, end) {
            let count = 0;
            let cur = new Date(start);
            while (cur <= end) {
                const day = cur.getDay();
                if (day !== 0 && day !== 6) count++;
                cur.setDate(cur.getDate() + 1);
            }
            return count;
        }

        const halfDayToggle   = document.getElementById('isHalfDay');
        const halfDayGroup    = document.getElementById('halfDayPeriodGroup');
        const endDateGroup    = document.getElementById('endDateGroup');
        const startDateInput  = document.getElementById('startDate');
        const endDateInput    = document.getElementById('endDate');
        const dayCountAlert   = document.getElementById('dayCountAlert');
        const dayCountEl      = document.getElementById('dayCount');
        const dayCountNote    = document.getElementById('dayCountNote');

        function updateDayCount() {
            const startVal = startDateInput.value;
            const endVal   = endDateInput.value;
            const isHalf   = halfDayToggle.checked;

            if (isHalf) {
                if (startVal) {
                    dayCountEl.textContent = '0.5';
                    dayCountNote.textContent = '(half day)';
                    dayCountAlert.style.display = 'block';
                } else {
                    dayCountAlert.style.display = 'none';
                }
                return;
            }

            if (startVal && endVal) {
                const start = new Date(startVal);
                const end   = new Date(endVal);
                if (end >= start) {
                    const days = countWorkdays(start, end);
                    dayCountEl.textContent = days;
                    dayCountNote.textContent = '(excluding weekends)';
                    dayCountAlert.style.display = 'block';
                } else {
                    dayCountAlert.style.display = 'none';
                }
            } else {
                dayCountAlert.style.display = 'none';
            }
        }

        function applyHalfDayMode() {
            const isHalf = halfDayToggle.checked;
            halfDayGroup.style.display = isHalf ? 'block' : 'none';

            if (isHalf) {
                // Lock end date to start date and hide the end date field
                endDateInput.value = startDateInput.value;
                endDateGroup.style.opacity = '0.5';
                endDateInput.readOnly = true;
            } else {
                endDateGroup.style.opacity = '1';
                endDateInput.readOnly = false;
            }
            updateDayCount();
        }

        halfDayToggle.addEventListener('change', applyHalfDayMode);

        startDateInput.addEventListener('change', function () {
            if (halfDayToggle.checked) {
                endDateInput.value = this.value;
            } else if (!endDateInput.value || endDateInput.value < this.value) {
                endDateInput.value = this.value;
            }
            updateDayCount();
        });

        endDateInput.addEventListener('change', updateDayCount);

        // Initialise on page load (handles validation round-trip)
        applyHalfDayMode();
        updateDayCount();
    </script>
}
