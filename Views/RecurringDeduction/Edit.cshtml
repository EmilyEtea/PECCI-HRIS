@model PECCI_HRIS.ViewModels.RecurringDeductionViewModel
@{
    ViewData["Title"] = "Edit Recurring Schedule";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-edit me-2"></i>Edit Recurring Schedule</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Recurring Schedules</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><i class="fas fa-sync-alt me-1"></i> Edit Schedule</div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ScheduleID" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="EmployeeID" class="form-label"></label>
                            <select asp-for="EmployeeID" asp-items="Model.Employees" class="form-select">
                                <option value="">Select Employee...</option>
                            </select>
                            <span asp-validation-for="EmployeeID" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DeductionType" class="form-label"></label>
                            <select asp-for="DeductionType" class="form-select">
                                <option value="">Select Type...</option>
                                <option value="SSS Loan">SSS Loan</option>
                                <option value="Pag-IBIG Loan">Pag-IBIG Loan</option>
                                <option value="PECCI Loan">PECCI Loan</option>
                                <option value="Cash Advance">Cash Advance</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="DeductionType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AmountPerCutoff" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input asp-for="AmountPerCutoff" type="number" step="0.01" min="0.01" class="form-control" />
                            </div>
                            <span asp-validation-for="AmountPerCutoff" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CutoffPeriod" class="form-label"></label>
                            <select asp-for="CutoffPeriod" class="form-select">
                                <option value="Both">Every cutoff (1–15 and 16–30)</option>
                                <option value="1-15">1–15 only</option>
                                <option value="16-30">16–30 only</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartDate" class="form-label"></label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndDate" class="form-label"></label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TotalInstallments" class="form-label"></label>
                            <input asp-for="TotalInstallments" type="number" min="1" class="form-control" />
                            <div class="form-text">Leave blank for unlimited.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-pecci-primary">
                            <i class="fas fa-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<div class="mt-4 text-center text-muted" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
