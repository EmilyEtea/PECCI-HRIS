@model IEnumerable<PECCI_HRIS.ViewModels.AttendanceSummaryRow>
@{
    ViewData["Title"] = "Attendance Summary";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHR = User.IsInRole("HR Admin") || User.IsInRole("HR Staff");
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-calendar-check me-2"></i>Attendance Summary</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Attendance</a></li>
                <li class="breadcrumb-item active">Summary</li>
            </ol>
        </nav>
    </div>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print">
        <i class="fas fa-print me-1"></i> Print
    </button>
</div>

<!-- Filters -->
<div class="card mb-3 no-print">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">Month</label>
                <select name="month" class="form-select form-select-sm">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(ViewBag.Month?.ToString() == m.ToString())">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label small mb-1">Year</label>
                <input type="number" name="year" class="form-control form-control-sm"
                       value="@(ViewBag.Year ?? DateTime.Today.Year)" min="2020" max="2099" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Cutoff Period</label>
                <select name="cutoff" class="form-select form-select-sm">
                    @{
                        var currentCutoff = (string?)ViewBag.Cutoff ?? "full";
                    }
                    @if (currentCutoff == "full")
                    {
                        <option value="full" selected>Full Month</option>
                        <option value="1-15">1st Half (1–15)</option>
                        <option value="16-end">2nd Half (16–end)</option>
                    }
                    else if (currentCutoff == "1-15")
                    {
                        <option value="full">Full Month</option>
                        <option value="1-15" selected>1st Half (1–15)</option>
                        <option value="16-end">2nd Half (16–end)</option>
                    }
                    else
                    {
                        <option value="full">Full Month</option>
                        <option value="1-15">1st Half (1–15)</option>
                        <option value="16-end" selected>2nd Half (16–end)</option>
                    }
                </select>
            </div>
            @if (isHR)
            {
                <div class="col-md-3">
                    <label class="form-label small mb-1">Employee</label>
                    <select name="employeeId" class="form-select form-select-sm">
                        <option value="">All Employees</option>
                        @if (ViewBag.Employees != null)
                        {
                            foreach (var emp in (List<PECCI_HRIS.Models.Employee>)ViewBag.Employees)
                            {
                                <option value="@emp.EmployeeID" selected="@(ViewBag.EmployeeId?.ToString() == emp.EmployeeID.ToString())">
                                    @emp.FullName
                                </option>
                            }
                        }
                    </select>
                </div>
            }
            <div class="col-md-2">
                <button type="submit" class="btn btn-pecci-primary btn-sm w-100">
                    <i class="fas fa-search me-1"></i> Filter
                </button>
            </div>
            <div class="col-md-1">
                <a asp-action="Summary" class="btn btn-outline-secondary btn-sm w-100" title="Clear">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </form>
    </div>
</div>

@* ── Period completeness warning ── *@
@if ((bool)(ViewBag.PeriodIsIncomplete ?? false))
{
    <div class="alert alert-warning d-flex align-items-start gap-3 mb-3 no-print" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg mt-1 flex-shrink-0"></i>
        <div>
            <strong>This period is not yet complete.</strong>
            The selected cutoff ends on
            <strong>@(((DateTime)ViewBag.PeriodEndDate).ToString("MMMM d, yyyy"))</strong>,
            which is still in the future. The summary below reflects attendance recorded
            so far and may be incomplete.
            <div class="mt-1 small text-muted">
                You can still view and print this report, but avoid using it for final
                payroll computation until the period has ended.
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">
        <i class="fas fa-list me-1"></i> Attendance Summary
        @if (ViewBag.PeriodLabel != null)
        {
            <span class="text-muted small ms-2">— @ViewBag.PeriodLabel</span>
        }
        @if ((bool)(ViewBag.PeriodIsIncomplete ?? false))
        {
            <span class="badge bg-warning text-dark ms-2" style="font-size:0.7rem;">
                <i class="fas fa-clock me-1"></i>In Progress
            </span>
        }
        <span class="badge ms-2" style="background:var(--pecci-green);">@Model.Count() employees</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-pecci mb-0">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th class="text-center">Present</th>
                        <th class="text-center">Late</th>
                        <th class="text-center">Absent</th>
                        <th class="text-center">On Leave</th>
                        <th class="text-center">Late Time</th>
                        <th class="text-center">Overtime</th>
                        <th class="text-center">Total Hours</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int sumPresent = 0, sumLate = 0, sumAbsent = 0, sumOnLeave = 0;
                        double sumLateMin = 0, sumOTMin = 0, sumHours = 0;
                    }
                    @foreach (var row in Model)
                    {
                        sumPresent  += row.TotalPresent;
                        sumLate     += row.TotalLate;
                        sumAbsent   += row.TotalAbsent;
                        sumOnLeave  += row.TotalOnLeave;
                        sumLateMin  += row.TotalLateMinutes;
                        sumOTMin    += row.TotalOvertimeMinutes;
                        sumHours    += row.TotalHoursWorked;
                        <tr>
                            <td>
                                <div class="fw-semibold">@row.Employee.FullName</div>
                                <div class="text-muted small">@row.Employee.EmployeeNo</div>
                            </td>
                            <td class="small">@row.Employee.Department?.DepartmentName</td>
                            <td class="text-center">
                                <span class="fw-semibold text-success">@row.TotalPresent</span>
                            </td>
                            <td class="text-center">
                                <span class="fw-semibold @(row.TotalLate > 0 ? "text-warning" : "text-muted")">@row.TotalLate</span>
                            </td>
                            <td class="text-center">
                                <span class="fw-semibold @(row.TotalAbsent > 0 ? "text-danger" : "text-muted")">@row.TotalAbsent</span>
                            </td>
                            <td class="text-center text-muted">@row.TotalOnLeave</td>
                            <td class="text-center small @(row.TotalLateMinutes > 0 ? "text-danger" : "text-muted")">
                                @row.LateMinutesDisplay
                            </td>
                            <td class="text-center small @(row.TotalOvertimeMinutes > 0 ? "text-success" : "text-muted")">
                                @row.OvertimeDisplay
                            </td>
                            <td class="text-center fw-semibold">@row.TotalHoursWorked.ToString("F2")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="fas fa-calendar-check fa-2x mb-2 d-block opacity-25"></i>
                                No attendance data found for the selected period.
                            </td>
                        </tr>
                    }
                </tbody>
                @if (Model.Any())
                {
                    <tfoot>
                        <tr style="background:var(--pecci-green-pale);font-weight:700;border-top:2px solid var(--pecci-green);">
                            <td colspan="2">Totals</td>
                            <td class="text-center text-success">@sumPresent</td>
                            <td class="text-center text-warning">@sumLate</td>
                            <td class="text-center text-danger">@sumAbsent</td>
                            <td class="text-center">@sumOnLeave</td>
                            <td class="text-center small">
                                @(sumLateMin >= 60 ? $"{(int)(sumLateMin/60)}h {(int)(sumLateMin%60)}m" : $"{(int)sumLateMin}m")
                            </td>
                            <td class="text-center small">
                                @(sumOTMin >= 60 ? $"{(int)(sumOTMin/60)}h {(int)(sumOTMin%60)}m" : $"{(int)sumOTMin}m")
                            </td>
                            <td class="text-center">@sumHours.ToString("F2")</td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

<div class="mt-3 text-center text-muted no-print" style="font-size:0.72rem;">
    <i class="fas fa-code me-1"></i>
    Developed by <strong>UST Interns</strong>:
    Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
</div>
