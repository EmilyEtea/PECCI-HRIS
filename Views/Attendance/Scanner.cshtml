@{
    ViewData["Title"] = "Attendance Scanner";
    Layout = null; // Full-screen kiosk — no sidebar
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PECCI Multipurpose Cooperative — Attendance Scanner</title>
    <link rel="icon" type="image/png" href="~/images/pecci-logo.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/images/pecci-logo.png" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --green: #2E7D32;
            --orange: #E8521A;
        }
        body {
            background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            color: white;
        }
        .scanner-card {
            background: white;
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 520px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            color: #1C2B1C;
        }
        .scanner-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .scanner-header img {
            height: 60px;
            object-fit: contain;
            margin-bottom: 0.75rem;
        }
        .scanner-header h4 {
            font-weight: 800;
            color: var(--green);
            margin: 0;
        }
        .scanner-header p {
            font-size: 0.8rem;
            color: #666;
            margin: 0;
        }
        #scanInput {
            font-size: 1.2rem;
            text-align: center;
            letter-spacing: 2px;
            border: 2px solid var(--green);
            border-radius: 10px;
            padding: 0.75rem;
        }
        #scanInput:focus {
            border-color: var(--orange);
            box-shadow: 0 0 0 0.2rem rgba(232,82,26,0.2);
            outline: none;
        }
        .result-box {
            border-radius: 12px;
            padding: 1.25rem;
            margin-top: 1.25rem;
            display: none;
            text-align: center;
        }
        .result-box.success-timein  { background: #E8F5E9; border: 2px solid #2E7D32; }
        .result-box.success-timeout { background: #E3F2FD; border: 2px solid #1565C0; }
        .result-box.late            { background: #FFF3E0; border: 2px solid #E65100; }
        .result-box.error           { background: #FFEBEE; border: 2px solid #C62828; }
        .result-box.pending         { background: #FFF8E1; border: 2px dashed #F57F17; }
        .result-name  { font-size: 1.4rem; font-weight: 800; }
        .result-dept  { font-size: 0.85rem; color: #555; }
        .result-time  { font-size: 2rem; font-weight: 900; font-family: monospace; }
        .result-action {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 0.5rem;
        }
        .action-in      { background: #2E7D32; color: white; }
        .action-out     { background: #1565C0; color: white; }
        .action-late    { background: #E65100; color: white; }
        .action-pending { background: #F57F17; color: white; }
        .clock {
            font-size: 2.5rem;
            font-weight: 900;
            font-family: monospace;
            color: var(--green);
            text-align: center;
            margin-bottom: 0.5rem;
        }
        .date-display {
            text-align: center;
            font-size: 0.85rem;
            color: #666;
            margin-bottom: 1.25rem;
        }
        .scan-hint {
            text-align: center;
            font-size: 0.8rem;
            color: #888;
            margin-top: 0.75rem;
        }
        .footer-credits {
            margin-top: 1.5rem;
            font-size: 0.65rem;
            color: rgba(255,255,255,0.5);
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="scanner-card">
        <div class="scanner-header">
            <img src="/images/pecci-logo.png" alt="PECCI Logo" />
            <h4>PECCI Multipurpose Cooperative</h4>
            <p>Attendance Time-In / Time-Out System</p>
        </div>

        <div class="clock" id="liveClock">--:--:--</div>
        <div class="date-display" id="liveDate"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-center d-block">
                <i class="fas fa-barcode me-1"></i> Scan Employee ID / Barcode
            </label>
            <input type="text" id="scanInput" class="form-control"
                   placeholder="Scan or type Employee No."
                   autocomplete="off" autofocus />
            <div class="scan-hint">
                <i class="fas fa-info-circle me-1"></i>
                Present your ID card to the scanner. First scan = Time In, second scan = Time Out.
            </div>
        </div>

        <div id="resultBox" class="result-box">
            <div id="resultAction" class="result-action"></div>
            <div id="resultName" class="result-name"></div>
            <div id="resultDept" class="result-dept"></div>
            <div id="resultTime" class="result-time"></div>
            <div id="resultMsg" class="mt-1" style="font-size:0.85rem;"></div>
        </div>

        <div id="errorBox" class="result-box error" style="display:none;">
            <i class="fas fa-exclamation-circle fa-2x text-danger mb-2 d-block"></i>
            <div id="errorMsg" class="fw-semibold text-danger"></div>
        </div>
    </div>

    <div class="footer-credits">
        PECCI Multipurpose Cooperative HRIS &bull; Developed by UST Interns:
        Arkin Reinier Aguilar &bull; Maxenne De Guzman &bull; Bernice Elyssa Soriano &bull; Emily Etea
    </div>

    <script>
        // ── Config from server (KioskSettings) ─────────────────────────────────
        const SCAN_TIMEOUT_MS        = @ViewBag.ScanTimeoutMs;
        const AUTO_RESET_MS          = @ViewBag.AutoResetSeconds * 1000;
        const ERROR_RESET_MS         = @ViewBag.ErrorResetSeconds * 1000;
        const PENDING_WINDOW_MS      = @ViewBag.PendingWindowSeconds * 1000;
        const API_KEY                = '@ViewBag.ApiKey';

        // ── Live clock ──────────────────────────────────────────────────────────
        function updateClock() {
            const now = new Date();
            document.getElementById('liveClock').textContent =
                now.toLocaleTimeString('en-PH', { hour12: false });
            document.getElementById('liveDate').textContent =
                now.toLocaleDateString('en-PH', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
        }
        updateClock();
        setInterval(updateClock, 1000);

        // ── Scanner input ───────────────────────────────────────────────────────
        const input = document.getElementById('scanInput');
        let scanTimeout;

        // Auto-submit after SCAN_TIMEOUT_MS of no typing (scanner sends all chars fast)
        input.addEventListener('input', () => {
            clearTimeout(scanTimeout);
            scanTimeout = setTimeout(() => {
                const val = input.value.trim();
                if (val.length >= 3) processScan(val);
            }, SCAN_TIMEOUT_MS);
        });

        // Also submit on Enter key
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                clearTimeout(scanTimeout);
                const val = input.value.trim();
                if (val.length >= 3) processScan(val);
            }
        });

        async function processScan(employeeNo) {
            input.value = '';
            input.focus();

            // Capture device IP via a public echo service if available,
            // otherwise fall back to empty string (server will use RemoteIpAddress).
            const deviceIP = '';

            const headers = { 'Content-Type': 'application/json' };
            if (API_KEY) headers['X-Api-Key'] = API_KEY;

            try {
                const res = await fetch('/Attendance/Scan', {
                    method: 'POST',
                    headers,
                    body: JSON.stringify({ employeeNo, deviceIP })
                });
                const data = await res.json();
                showResult(data);
            } catch (err) {
                showError('Connection error. Please try again.');
            }
        }

        function showResult(data) {
            const resultBox = document.getElementById('resultBox');
            const errorBox  = document.getElementById('errorBox');

            if (!data.success) {
                errorBox.style.display = 'block';
                resultBox.style.display = 'none';
                document.getElementById('errorMsg').textContent = data.message;
                setTimeout(() => { errorBox.style.display = 'none'; }, ERROR_RESET_MS);
                return;
            }

            errorBox.style.display = 'none';

            const isIn      = data.action === 'TIME IN';
            const isLate    = data.isLate;
            const isPending = data.isPending;

            // Pending state — waiting for confirmation scan
            if (isPending) {
                resultBox.className = 'result-box pending';
                resultBox.style.display = 'block';

                const actionEl = document.getElementById('resultAction');
                actionEl.textContent = data.action;
                actionEl.className = 'result-action action-pending';

                document.getElementById('resultName').textContent = data.employeeName;
                document.getElementById('resultDept').textContent = data.department;
                document.getElementById('resultTime').textContent = data.timeRecorded;
                document.getElementById('resultMsg').textContent  = data.message;

                setTimeout(() => { resultBox.style.display = 'none'; }, PENDING_WINDOW_MS);
                return;
            }

            // Confirmed scan
            const scheme = isIn
                ? (isLate ? 'late' : 'success-timein')
                : 'success-timeout';

            resultBox.className = 'result-box ' + scheme;
            resultBox.style.display = 'block';

            const actionEl = document.getElementById('resultAction');
            actionEl.textContent = data.action;
            actionEl.className = 'result-action ' + (isIn ? (isLate ? 'action-late' : 'action-in') : 'action-out');

            document.getElementById('resultName').textContent = data.employeeName;
            document.getElementById('resultDept').textContent = data.department;
            document.getElementById('resultTime').textContent = data.timeRecorded;
            document.getElementById('resultMsg').textContent  = data.message;

            setTimeout(() => { resultBox.style.display = 'none'; }, AUTO_RESET_MS);
        }

        function showError(msg) {
            const errorBox = document.getElementById('errorBox');
            errorBox.style.display = 'block';
            document.getElementById('errorMsg').textContent = msg;
            setTimeout(() => { errorBox.style.display = 'none'; }, ERROR_RESET_MS);
        }

        // Keep focus on input always
        document.addEventListener('click', () => input.focus());
        setInterval(() => input.focus(), 3000);
    </script>
</body>
</html>
